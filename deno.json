{
  "tasks": {
    "ix": "deno run --allow-read --allow-write ix.ts",
    "lsp:perf": "deno run --allow-read scripts/lsp-performance.ts"
  },
  "imports": {
    "@mewhhaha/typeclasses": "jsr:@mewhhaha/typeclasses@^0.5.0"
  },
  "minimumDependencyAge": {
    "age": "P7D",
    "exclude": [
      "jsr:@mewhhaha/*"
    ]
  },
  "fmt": {
    "exclude": [
      "AGENTS.md",
      "tree-sitter-ix/src/grammar.json",
      "tree-sitter-ix/src/node-types.json"
    ]
  }
}
