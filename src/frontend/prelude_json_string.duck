module () where

const { text_append, text_get, text_length, text_slice } = import "duck:prelude/runtime" ()

let encode_json_string: Text -> Text = text => {
  let encoded: Text = "\""
  let index = 0
  let segment_start = 0

  loop {
    if index >= text_length text { break }
    let byte = text_get [text, index]

    if byte == 34 || byte == 92 || byte < 32 {
      encoded = text_append [encoded, text_slice [text, segment_start, index]]

      if byte == 34 {
        encoded = text_append [encoded, "\\\""]
      } else if byte == 92 {
        encoded = text_append [encoded, "\\\\"]
      } else if byte == 8 {
        encoded = text_append [encoded, "\\b"]
      } else if byte == 9 {
        encoded = text_append [encoded, "\\t"]
      } else if byte == 10 {
        encoded = text_append [encoded, "\\n"]
      } else if byte == 12 {
        encoded = text_append [encoded, "\\f"]
      } else if byte == 13 {
        encoded = text_append [encoded, "\\r"]
      } else {
        let high = byte / 16
        let low = byte % 16
        encoded = text_append [encoded, "\\u00"]
        encoded = text_append [encoded, text_slice ["0123456789abcdef", high, high + 1]]
        encoded = text_append [encoded, text_slice ["0123456789abcdef", low, low + 1]]
      }

      index = index + 1
      segment_start = index
    } else {
      index = index + 1
    }
  }

  encoded = text_append [encoded, text_slice [text, segment_start, index]]
  text_append [encoded, "\""]
}

return { encode_json_string }
