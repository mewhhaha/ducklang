module () where

const { .not, .slice } = import "duck:prelude" ();
const { .struct } = import "duck:prelude/types" ();

type IteratorValue state item = struct {
  .state = state,
  .has_next = state -> Bool,
  .next = state -> [item, state],
}

type IndexedIteratorState collection = struct {
  .collection = collection,
  .index = I32,
  .length = I32,
}

type MappedIteratorState source_state input output = struct {
  .source = source_state,
  .source_has_next = source_state -> Bool,
  .source_next = source_state -> [input, source_state],
  .transform = input -> output,
}

type ZippedIteratorState left_state right_state left_item right_item = struct {
  .left = left_state,
  .left_has_next = left_state -> Bool,
  .left_next = left_state -> [left_item, left_state],
  .right = right_state,
  .right_has_next = right_state -> Bool,
  .right_next = right_state -> [right_item, right_state],
}

type ZippedItem left right = [left, right]

type ScannedIteratorState source_state item state = struct {
  .source = source_state,
  .source_has_next = source_state -> Bool,
  .source_next = source_state -> [item, source_state],
  .state = state,
  .combine = state -> item -> state,
}

type ByteWindowState = struct {
  .bytes = Bytes,
  .index = I32,
  .length = I32,
  .width = I32,
}

duck IntoIterator Self {
  type Cursor
  .iterator = Self -> Cursor
}

extend IteratorValue State Element {
  type Item = Element,
  .has_next = (iterator: IteratorValue State Element) => {
    iterator.has_next(iterator.state)
  },
  .next = (iterator: IteratorValue State Element) => {
    let [item, state] = iterator.next(iterator.state);
    let next: IteratorValue State Element = [
      .state = state,
      .has_next = iterator.has_next,
      .next = iterator.next,
    ];
    [item, next]
  },
}

extend Bytes {
  type Cursor = IteratorValue(IndexedIteratorState Bytes) I32,
  .iterator = bytes => {
    let state: IndexedIteratorState Bytes = [.collection = bytes, .index = 0, .length = @len bytes];
    let has_next = (state: IndexedIteratorState Bytes) => {
      state.index < state.length
    };
    let next: IndexedIteratorState Bytes -> [
      I32,
      IndexedIteratorState Bytes,
    ] = (state: IndexedIteratorState Bytes) => {
      let item = @get(&state.collection, state.index);
      let next_state: IndexedIteratorState Bytes = [
        .collection = state.collection,
        .index = state.index + 1,
        .length = state.length,
      ];
      [item, next_state]
    };
    let iterator: IteratorValue(IndexedIteratorState Bytes) I32 = [
      .state = state,
      .has_next = has_next,
      .next = next,
    ];
    iterator
  },
}

extend Text {
  type Cursor = IteratorValue(IndexedIteratorState Text) I32,
  .iterator = text => {
    let state: IndexedIteratorState Text = [.collection = text, .index = 0, .length = @len text];
    let has_next = (state: IndexedIteratorState Text) => {
      state.index < state.length
    };
    let next: IndexedIteratorState Text -> [
      I32,
      IndexedIteratorState Text,
    ] = (state: IndexedIteratorState Text) => {
      let item = @get(&state.collection, state.index);
      let next_state: IndexedIteratorState Text = [
        .collection = state.collection,
        .index = state.index + 1,
        .length = state.length,
      ];
      [item, next_state]
    };
    let iterator: IteratorValue(IndexedIteratorState Text) I32 = [
      .state = state,
      .has_next = has_next,
      .next = next,
    ];
    iterator
  },
}

const iterator_map: forall source_state input output.[
  IteratorValue source_state input,
  input -> output,
] -> IteratorValue(MappedIteratorState source_state input output) output =
  (source, transform) => {
    let state: MappedIteratorState source_state input output = [
      .source = source.state,
      .source_has_next = source.has_next,
      .source_next = source.next,
      .transform = transform,
    ];
    let has_next = (state: MappedIteratorState source_state input output) => {
      state.source_has_next(state.source)
    };
    let next: MappedIteratorState source_state input output -> [
      output,
      MappedIteratorState source_state input output,
    ] =
      state => {
        let [item, source] = state.source_next(state.source);
        let next_state: MappedIteratorState source_state input output = [
          .source = source,
          .source_has_next = state.source_has_next,
          .source_next = state.source_next,
          .transform = state.transform,
        ];
        let output = state.transform(item);
        [output, next_state]
      };
    let iterator: IteratorValue(MappedIteratorState source_state input output) output = [
      .state = state,
      .has_next = has_next,
      .next = next,
    ];
    iterator
  };

const iterator_zip: forall left_state right_state left_item right_item.[
  IteratorValue left_state left_item,
  IteratorValue right_state right_item,
] ->
  IteratorValue(ZippedIteratorState left_state right_state left_item right_item)(
    ZippedItem left_item right_item
  ) =
  (left, right) => {
    let state: ZippedIteratorState left_state right_state left_item right_item = [
      .left = left.state,
      .left_has_next = left.has_next,
      .left_next = left.next,
      .right = right.state,
      .right_has_next = right.has_next,
      .right_next = right.next,
    ];
    let has_next = (state: ZippedIteratorState left_state right_state left_item right_item) => {
      state.left_has_next(state.left) && state.right_has_next(state.right)
    };
    let next: ZippedIteratorState left_state right_state left_item right_item -> [
      ZippedItem left_item right_item,
      ZippedIteratorState left_state right_state left_item right_item,
    ] =
      state => {
        let [left_value, left] = state.left_next(state.left);
        let [right_value, right] = state.right_next(state.right);
        let next_state: ZippedIteratorState left_state right_state left_item right_item = [
          .left = left,
          .left_has_next = state.left_has_next,
          .left_next = state.left_next,
          .right = right,
          .right_has_next = state.right_has_next,
          .right_next = state.right_next,
        ];
        let pair: ZippedItem left_item right_item = [left_value, right_value];
        [pair, next_state]
      };
    let iterator: IteratorValue(ZippedIteratorState left_state right_state left_item right_item)(
      ZippedItem left_item right_item
    ) = [
      .state = state,
      .has_next = has_next,
      .next = next,
    ];
    iterator
  };

const iterator_scan: forall source_state item state.[
  IteratorValue source_state item,
  state,
  state -> item -> state,
] -> IteratorValue(ScannedIteratorState source_state item state) state =
  (source, initial, combine) => {
    let state: ScannedIteratorState source_state item state = [
      .source = source.state,
      .source_has_next = source.has_next,
      .source_next = source.next,
      .state = initial,
      .combine = combine,
    ];
    let has_next = (state: ScannedIteratorState source_state item state) => {
      state.source_has_next(state.source)
    };
    let next: ScannedIteratorState source_state item state -> [
      state,
      ScannedIteratorState source_state item state,
    ] =
      iterator_state => {
        let [item, source] = iterator_state.source_next(iterator_state.source);
        let combined = iterator_state.combine(iterator_state.state)(item);
        let next_state: ScannedIteratorState source_state item state = [
          .source = source,
          .source_has_next = iterator_state.source_has_next,
          .source_next = iterator_state.source_next,
          .state = combined,
          .combine = iterator_state.combine,
        ];
        [combined, next_state]
      };
    let iterator: IteratorValue(ScannedIteratorState source_state item state) state = [
      .state = state,
      .has_next = has_next,
      .next = next,
    ];
    iterator
  };

const iterator_fold: forall source_state item state.[
  IteratorValue source_state item,
  state,
  state -> item -> state,
] -> state =
  (source, initial, combine) => {
    let state = initial;
    let current = source.state;

    loop {
      if not(source.has_next(current)) { break; }
      let [item, next] = source.next(current);
      current = next
      state = combine(state)(item)
    }

    state
  };

const iterator_find: forall source_state item.[
  IteratorValue source_state item,
  item -> Bool,
] -> Option item =
  (source, predicate) => {
    let found: Option item = `None ();
    let current = source.state;

    loop {
      if not(source.has_next(current)) { break; }
      let [item, next] = source.next(current);
      current = next

      if predicate item {
        found = `Some item
        break;
      }
    }

    found
  };

const iterator_find_index: forall source_state item.[
  IteratorValue source_state item,
  item -> Bool,
] -> Option I32 =
  (source, predicate) => {
    let found: Option I32 = `None ();
    let current = source.state;
    let index = 0;

    loop {
      if not(source.has_next(current)) { break; }
      let [item, next] = source.next(current);
      current = next

      if predicate item {
        found = `Some index
        break;
      }

      index = index + 1
    }

    found
  };

const iterator_count: forall source_state item.[
  IteratorValue source_state item,
  item -> Bool,
] -> I32 =
  (source, predicate) => {
    let current = source.state;
    let count = 0;

    loop {
      if not(source.has_next(current)) { break; }
      let [item, next] = source.next(current);
      current = next

      if predicate item {
        count = count + 1
      }
    }

    count
  };

const iterator_windows = (bytes: Bytes, width: I32) => {
  let length = @len bytes;
  let state: ByteWindowState = [.bytes = bytes, .index = 0, .length = length, .width = width];
  let has_next = (state: ByteWindowState) => {
    state.width > 0 && state.index < state.length
  };
  let next: ByteWindowState -> [Bytes, ByteWindowState] = (state: ByteWindowState) => {
    let remaining = state.length - state.index;
    let window_length = if remaining < state.width { remaining } else { state.width };
    let window = slice(&state.bytes, state.index, state.index + window_length);
    let next_state: ByteWindowState = [
      .bytes = state.bytes,
      .index = state.index + 1,
      .length = state.length,
      .width = state.width,
    ];
    [window, next_state]
  };
  let iterator: IteratorValue ByteWindowState Bytes = [
    .state = state,
    .has_next = has_next,
    .next = next,
  ];
  iterator
};

return {
  .iterator_map,
  .iterator_zip,
  .iterator_scan,
  .iterator_fold,
  .iterator_find,
  .iterator_find_index,
  .iterator_count,
  .iterator_windows,
};
