module () where

declare effect Process {
  arg_count: () => I32
  arg: (I32) => Text
  cwd: () => Text
}

declare effect Walk {
  begin: (&Text) => OpenResult
  next: () => WalkEvent
  prune: () => Unit
  end: () => Unit
}

declare effect FileReader {
  open: (&Text) => OpenResult
  read: (I32) => ReadResult
  close: () => Unit
}

declare effect Stdin {
  read: (I32) => ReadResult
  is_terminal: () => I32
}

declare effect Stdout {
  write: (&Bytes) => WriteResult
  is_terminal: () => I32
}

declare effect Stderr {
  write: (&Bytes) => WriteResult
  is_terminal: () => I32
}

declare Init {
  process: Process
  walk: Walk
  file_reader: FileReader
  stdin: Stdin
  stdout: Stdout
  stderr: Stderr
}

return {}
