module () where

const { .struct } = import "duck:prelude" ();
const { .list } = import "duck:prelude/functional" ();
const { .text_append, .text_find, .text_length, .text_longest_suffix_prefix_length, .text_slice } =
  import "duck:prelude/runtime" ();

type CitationParser = struct {
  .pending = Text,
  .active = Bool,
  .content = Text
}

type Citations = List Text
type CitationChunk = [CitationParser, Text, Citations]

const texts = comptime list Text;
const citation_open = "<oai-mem-citation>";
const citation_close = "</oai-mem-citation>";

let new_citation_parser: [] -> CitationParser = () => ["", false, ""];

let push_citation_chunk: [CitationParser, Text] -> CitationChunk =
  (parser: CitationParser, chunk: Text) => {
    let pending: Text = text_append [parser.pending, chunk];
    let active: Bool = parser.active;
    let content: Text = parser.content;
    let visible_text: Text = "";
    let citations: Citations = texts.empty();

    loop {
      if active {
        let close_index = text_find [pending, citation_close];

        if close_index >= 0 {
          let prefix = text_slice [pending, 0, close_index];
          content = text_append [content, prefix]
          citations = texts.prepend(content, citations)
          content = ""
          pending = text_slice [
            pending,
            close_index + text_length citation_close,
            text_length pending,
          ]
          active = false
        } else {
          let keep = text_longest_suffix_prefix_length [pending, citation_close];
          let take = text_length pending - keep;

          if take > 0 {
            let prefix = text_slice [pending, 0, take];
            content = text_append [content, prefix]
            pending = text_slice [pending, take, text_length pending]
          }

          break;
        }
      } else {
        let open_index = text_find [pending, citation_open];

        if open_index >= 0 {
          let prefix = text_slice [pending, 0, open_index];
          visible_text = text_append [visible_text, prefix]
          pending = text_slice [
            pending,
            open_index + text_length citation_open,
            text_length pending,
          ]
          active = true
        } else {
          let keep = text_longest_suffix_prefix_length [pending, citation_open];
          let take = text_length pending - keep;

          if take > 0 {
            let prefix = text_slice [pending, 0, take];
            visible_text = text_append [visible_text, prefix]
            pending = text_slice [pending, take, text_length pending]
          }

          break;
        }
      }
    }

    let next_parser: CitationParser = [pending, active, content];
    [next_parser, visible_text, texts.reverse(citations)]
  };

let finish_citations: CitationParser -> CitationChunk =
  (parser: CitationParser) => {
    let citations: Citations = texts.empty();
    let visible_text: Text = "";

    if parser.active {
      let content = text_append [parser.content, parser.pending];
      citations = texts.singleton(content)
    } else {
      visible_text = parser.pending
    }

    [["", false, ""] as CitationParser, visible_text, citations]
  };

return {
  .new_citation_parser,
  .push_citation_chunk,
  .finish_citations
};
