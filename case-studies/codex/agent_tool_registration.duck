module () where

const {} = import "./agent_tool_types.duck" ();
const {} = import "./tool_types.duck" ();

type AgentRegistrationDefinitionNode = [ToolDefinition, AgentRegistrationDefinitions]
type AgentRegistrationDefinitions =
  | `Nil Unit
  | `Cons AgentRegistrationDefinitionNode
type AgentRegistrationSpecNode = [ToolSpec, AgentRegistrationSpecs]
type AgentRegistrationSpecs =
  | `Nil Unit
  | `Cons AgentRegistrationSpecNode

const collaboration_tool_name: [AgentToolRegistrationConfig, Text] -> ToolName = (
  config,
  local_name,
) => {
  [config.namespace, local_name]
};

const collaboration_tool_exposure: AgentToolRegistrationConfig -> ToolExposure = config => {
  if config.direct_model_only { `DirectModelOnly () } else { `Direct () }
};

const collaboration_tool_definition: [AgentToolRegistrationConfig, Text, ToolHandler, Bool] ->
  ToolDefinition = (
    config,
    local_name,
    tool_handler,
    parallel,
  ) => {
    [
      collaboration_tool_name(config, local_name),
      collaboration_tool_exposure config,
      tool_handler,
      `FunctionPayload (),
      parallel,
      false,
    ]
  };

const collaboration_tools_enabled: AgentToolRegistrationConfig -> Bool = config => {
  config.enabled && config.v2_enabled
};

const collaboration_tool_definitions: AgentToolRegistrationConfig -> AgentRegistrationDefinitions =
  config => {
    if !(collaboration_tools_enabled config) {
      return `Nil ();
    }

    let spawn = collaboration_tool_definition(config, "spawn_agent", `SpawnAgent (), false);
    let send = collaboration_tool_definition(config, "send_message", `SendAgentMessage (), true);
    let followup = collaboration_tool_definition(
      config,
      "followup_task",
      `FollowupAgentTask (),
      true,
    );
    let wait = collaboration_tool_definition(config, "wait_agent", `WaitAgent (), false);
    let interrupt = collaboration_tool_definition(
      config,
      "interrupt_agent",
      `InterruptAgent (),
      true,
    );
    let list = collaboration_tool_definition(config, "list_agents", `ListAgents (), true);
    `Cons [
      spawn,
      `Cons [send, `Cons [followup, `Cons [wait, `Cons [interrupt, `Cons [list, `Nil ()]]]]],
    ]
  };

const collaboration_tool_spec: [AgentToolRegistrationConfig, Text, Text, Text, ToolOutputSchema] ->
  ToolSpec = (
    config,
    local_name,
    description,
    parameters,
    output_schema,
  ) => {
    [
      collaboration_tool_name(config, local_name),
      `FunctionSpec (),
      description,
      parameters,
      output_schema,
      false,
    ]
  };

const collaboration_tool_specs: AgentToolRegistrationConfig -> AgentRegistrationSpecs = config => {
  if !(collaboration_tools_enabled config) {
    return `Nil ();
  }

  let spawn_description =
    "Spawns an agent to work on the specified task. The spawned agent inherits the parent model and reasoning effort unless an explicit override is requested. Only call this tool for a concrete, bounded subtask that can run independently alongside useful local work.";
  let spawn_parameters =
    "{\"type\":\"object\",\"properties\":{\"fork_turns\":{\"type\":\"string\",\"description\":\"Optional number of turns to fork. Defaults to `all`. Use `none`, `all`, or a positive integer string such as `3`.\"},\"message\":{\"type\":\"string\",\"description\":\"Initial plain-text task for the new agent.\"},\"model\":{\"type\":\"string\",\"description\":\"Model override for the new agent. Omit unless an explicit override is needed.\"},\"reasoning_effort\":{\"type\":\"string\",\"description\":\"Reasoning effort override for the new agent. Omit to inherit the parent effort.\"},\"task_name\":{\"type\":\"string\",\"description\":\"Task name for the new agent. Use lowercase letters, digits, and underscores.\"}},\"required\":[\"task_name\",\"message\"],\"additionalProperties\":false}";
  let spawn_output = if config.hide_spawn_metadata {
    "{\"type\":\"object\",\"properties\":{\"task_name\":{\"type\":\"string\",\"description\":\"Canonical task name for the spawned agent.\"}},\"required\":[\"task_name\"],\"additionalProperties\":false}"
  } else {
    "{\"type\":\"object\",\"properties\":{\"task_name\":{\"type\":\"string\",\"description\":\"Canonical task name for the spawned agent.\"},\"nickname\":{\"type\":[\"string\",\"null\"],\"description\":\"User-facing nickname for the spawned agent when available.\"}},\"required\":[\"task_name\",\"nickname\"],\"additionalProperties\":false}"
  };
  let spawn = collaboration_tool_spec(
    config,
    "spawn_agent",
    spawn_description,
    spawn_parameters,
    `ToolOutputSchemaPresent spawn_output,
  );

  let send_description =
    "Send a message to an existing agent. The message will be delivered promptly. Does not trigger a new turn.";
  let message_parameters =
    "{\"type\":\"object\",\"properties\":{\"target\":{\"type\":\"string\",\"description\":\"Relative or canonical task name to message (from spawn_agent).\"},\"message\":{\"type\":\"string\",\"description\":\"Message text to queue on the target agent.\"}},\"required\":[\"target\",\"message\"],\"additionalProperties\":false}";
  let send = collaboration_tool_spec(
    config,
    "send_message",
    send_description,
    message_parameters,
    `ToolOutputSchemaMissing (),
  );

  let followup_description =
    "Send a follow-up task to an existing non-root target agent and trigger a turn if it is idle. If the target is already running, deliver the task promptly at message boundaries while sampling, or after the pending tool call completes.";
  let followup_parameters =
    "{\"type\":\"object\",\"properties\":{\"target\":{\"type\":\"string\",\"description\":\"Agent id or canonical task name to send a follow-up task to (from spawn_agent).\"},\"message\":{\"type\":\"string\",\"description\":\"Message text to send to the target agent.\"}},\"required\":[\"target\",\"message\"],\"additionalProperties\":false}";
  let followup = collaboration_tool_spec(
    config,
    "followup_task",
    followup_description,
    followup_parameters,
    `ToolOutputSchemaMissing (),
  );

  let wait_description =
    "Wait for a mailbox update from any live agent, including queued messages and final-status notifications. The wait also ends early when new user input is steered into the active turn. Does not return the content; returns either an update, interruption, or timeout summary.";
  let wait_parameters =
    "{\"type\":\"object\",\"properties\":{\"timeout_ms\":{\"type\":\"number\",\"description\":\"Timeout in milliseconds. Defaults to 30000, min 10000, max 3600000.\"}},\"additionalProperties\":false}";
  let wait_output =
    "{\"type\":\"object\",\"properties\":{\"message\":{\"type\":\"string\",\"description\":\"Brief wait summary without the agent's final content.\"},\"timed_out\":{\"type\":\"boolean\",\"description\":\"Whether no mailbox update arrived before the timeout.\"}},\"required\":[\"message\",\"timed_out\"],\"additionalProperties\":false}";
  let wait = collaboration_tool_spec(
    config,
    "wait_agent",
    wait_description,
    wait_parameters,
    `ToolOutputSchemaPresent wait_output,
  );

  let interrupt_description =
    "Interrupt an agent's current turn, if any, and return its previous status. The agent remains available for messages and follow-up tasks.";
  let target_parameters =
    "{\"type\":\"object\",\"properties\":{\"target\":{\"type\":\"string\",\"description\":\"Agent id or canonical task name to interrupt (from spawn_agent).\"}},\"required\":[\"target\"],\"additionalProperties\":false}";
  let previous_status_output =
    "{\"type\":\"object\",\"properties\":{\"previous_status\":{\"description\":\"The agent status observed before the interrupt request was handled.\",\"allOf\":[{\"oneOf\":[{\"type\":\"string\",\"enum\":[\"pending_init\",\"running\",\"interrupted\",\"shutdown\",\"not_found\"]},{\"type\":\"object\",\"properties\":{\"completed\":{\"type\":[\"string\",\"null\"]}},\"required\":[\"completed\"],\"additionalProperties\":false},{\"type\":\"object\",\"properties\":{\"errored\":{\"type\":\"string\"}},\"required\":[\"errored\"],\"additionalProperties\":false}]}]}},\"required\":[\"previous_status\"],\"additionalProperties\":false}";
  let interrupt = collaboration_tool_spec(
    config,
    "interrupt_agent",
    interrupt_description,
    target_parameters,
    `ToolOutputSchemaPresent previous_status_output,
  );

  let list_description =
    "List live agents in the current root thread tree. Optionally filter by task-path prefix.";
  let list_parameters =
    "{\"type\":\"object\",\"properties\":{\"path_prefix\":{\"type\":\"string\",\"description\":\"Task-path prefix filter without a trailing slash. Omit to list all live agents.\"}},\"additionalProperties\":false}";
  let list_output =
    "{\"type\":\"object\",\"properties\":{\"agents\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"agent_name\":{\"type\":\"string\",\"description\":\"Canonical task name for the agent when available, otherwise the agent id.\"},\"agent_status\":{\"description\":\"Last known status of the agent.\",\"allOf\":[{\"oneOf\":[{\"type\":\"string\",\"enum\":[\"pending_init\",\"running\",\"interrupted\",\"shutdown\",\"not_found\"]},{\"type\":\"object\",\"properties\":{\"completed\":{\"type\":[\"string\",\"null\"]}},\"required\":[\"completed\"],\"additionalProperties\":false},{\"type\":\"object\",\"properties\":{\"errored\":{\"type\":\"string\"}},\"required\":[\"errored\"],\"additionalProperties\":false}]}]}},\"required\":[\"agent_name\",\"agent_status\"],\"additionalProperties\":false},\"description\":\"Live agents visible in the current root thread tree.\"}},\"required\":[\"agents\"],\"additionalProperties\":false}";
  let list = collaboration_tool_spec(
    config,
    "list_agents",
    list_description,
    list_parameters,
    `ToolOutputSchemaPresent list_output,
  );

  `Cons [
    spawn,
    `Cons [send, `Cons [followup, `Cons [wait, `Cons [interrupt, `Cons [list, `Nil ()]]]]],
  ]
};

return {
  .collaboration_tool_definitions,
  .collaboration_tool_specs,
  .collaboration_tools_enabled,
};
