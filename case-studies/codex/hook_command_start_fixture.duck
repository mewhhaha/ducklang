module () where

const { .list } = import "duck:prelude/functional" ();
const hook_types_module = import "./hook_types.duck";
const hook_command_module = import "./hook_command.duck";
const { .action_is_continue, .evaluate_hook_command } = hook_command_module();

type FixtureResult = HookCommandResult
type FixtureTexts = HookTexts

const fixture_texts = comptime list Text;

let score: I32 = 0;

let session_context: FixtureResult = [`None (), `Some 0, "session context", ""];
let [session_status, _, _, session_contexts, _, _, _] = evaluate_hook_command(
  `SessionStart (),
  session_context,
);
if let `Completed () = session_status {
  if fixture_texts.nth_or("", 0, session_contexts) == "session context" { score = score + 1 }
}

let subagent_continue_false: FixtureResult = [
  `None (),
  `Some 0,
  "{\"continue\":false,\"stopReason\":\"ignored\",\"hookSpecificOutput\":{\"hookEventName\":\"SubagentStart\",\"additionalContext\":\"child context\"}}",
  "",
];
let [subagent_status, _, subagent_action, subagent_contexts, _, _, _] = evaluate_hook_command(
  `SubagentStart (),
  subagent_continue_false,
);
if let `Completed () = subagent_status {
  if action_is_continue subagent_action {
    if fixture_texts.nth_or("", 0, subagent_contexts) == "child context" { score = score + 1 }
  }
}

return { .score = score };
