module () where

const { list } = import "duck:prelude/functional" ()
const exec_types_module = import "./exec_types.duck"
const command_canonicalization_module = import "./command_canonicalization.duck"
const { canonicalize_command_for_approval } = command_canonicalization_module()

type FixtureTexts = ExecTexts

const texts = comptime list(Text)
const command3 = (first: Text, second: Text, third: Text) => texts.prepend(first, texts.prepend(second, texts.singleton(third)))

let command: FixtureTexts = canonicalize_command_for_approval(command3("/bin/bash", "-lc", "cargo   test   -p codex-core"))
let matches = texts.length(command) == 4 && texts.nth_or("", 0, command) == "cargo" && texts.nth_or("", 1, command) == "test" && texts.nth_or("", 2, command) == "-p" && texts.nth_or("", 3, command) == "codex-core"

return { .score = if matches { 1 } else { 0 } }
