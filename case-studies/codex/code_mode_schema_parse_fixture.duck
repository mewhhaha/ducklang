module () where

const { .json_object_get } = import "duck:prelude/json/values" ();
const { .text_contains } = import "duck:prelude/runtime" ();
const { .parse_code_mode_schema } = import "./code_mode_schema_parse.duck" ();

let score = 0;

let missing = parse_code_mode_schema("weather", "input", `CodeModeSchemaDocumentMissing ());
if let `CodeModeParsedSchemaMissing () = missing { score = score + 1 }

let parsed = parse_code_mode_schema(
  "weather",
  "input",
  `CodeModeSchemaDocumentPresent "{\"type\":\"object\"}",
);
if let `CodeModeParsedSchemaPresent schema = parsed {
  if let `Object object = schema {
    if let `Found value = json_object_get("type", object) {
      if let `String name = value {
        if name == "object" { score = score + 10 }
      }
    }
  }
}

let invalid = parse_code_mode_schema("weather", "output", `CodeModeSchemaDocumentPresent "{");
if let `CodeModeParsedSchemaFailed message = invalid {
  if text_contains(message, "tool weather output schema at byte") { score = score + 100 }
}

return { .score = score };
