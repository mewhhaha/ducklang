module () where

const { json_array, json_array_empty, json_object, json_object_empty, json_object_prepend, json_string } = import "duck:prelude/json" ()
const { plan_decoded_thread_resume } = import "./app_server_thread_lifecycle.duck" ()
const { decode_thread_resume } = import "./app_server_thread_methods.duck" ()
const {} = import "./app_server_thread_lifecycle_types.duck" ()

type FixtureDecodeResult = AppServerMethodDecodeResult
type FixtureLoadedThreads = AppServerLoadedThreads
type FixturePlanInput = AppServerDecodedThreadResumePlanInput
type FixturePlanResult = AppServerThreadResumePlanResult

let fields = json_object_empty()
fields = json_object_prepend("path", json_string("/rollouts/thread-1.jsonl"), fields)
fields = json_object_prepend("history", json_array(json_array_empty()), fields)
fields = json_object_prepend("threadId", json_string("thread-1"), fields)
let decoded: FixtureDecodeResult = decode_thread_resume(json_object(fields))
let loaded: FixtureLoadedThreads = `Nil ()
let score = if let `MethodOk method = decoded {
  if let `ThreadResume params = method {
    let input: FixturePlanInput = [params, loaded]
    let planned: FixturePlanResult = plan_decoded_thread_resume(input)
    if let `Ok plan = planned {
      if let `ResumeHistory history = plan.source {
        if let `Array _ = history { 1 } else { 0 }
      } else { 0 }
    } else { 0 }
  } else { 0 }
} else { 0 }

return { .score = score }
