module (!init: Init) where

const { list } = import "duck:prelude/functional" ()
const exec_types_module = import "./exec_types.duck"
const exec_module = import "./exec.duck"
const { clamp_initial_yield_time, process_succeeded, resolve_command } = exec_module()
const tool_types_module = import "./tool_types.duck"
const tool_policy_module = import "./tool_policy.duck"
const { plan_sandbox_retry } = tool_policy_module()

type FixtureTextOption = ExecTextOption
type FixtureBoolOption = ExecBoolOption
type FixtureShell = ExecShell
type FixtureShellMode = ExecShellMode
type FixtureResolution = ExecCommandResolution
type FixtureLaunch = ExecLaunch
type FixtureSnapshot = ExecProcessSnapshot
type FixtureApproval = ToolApprovalPolicy
type FixtureSandboxKind = ToolFileSystemSandboxKind
type FixtureSandbox = ToolFileSystemSandbox
type FixtureRetryDecision = ToolSandboxRetryDecision

const texts = comptime list(Text)

let session_shell: FixtureShell = ["/bin/zsh", `Zsh ()]
let shell_mode: FixtureShellMode = `Direct ()
let no_shell: FixtureTextOption = `None ()
let no_login: FixtureBoolOption = `Some false
let resolution: FixtureResolution = resolve_command("pwd", no_shell, no_login, shell_mode, session_shell, false)
let restricted_kind: FixtureSandboxKind = `Restricted ()
let sandbox: FixtureSandbox = [restricted_kind, texts.singleton("/repo"), false, false]
let policy: FixtureApproval = `UnlessTrusted ()
let score: I32 = 0

if let `Ok resolved = resolution {
  let [command, _] = resolved
  let cwd = "/repo"
  let yield_time = clamp_initial_yield_time(10, false)
  let first_launch: FixtureLaunch = [texts.nth_or("", 0, command), texts.nth_or("", 1, command), texts.nth_or("", 2, command), texts.nth_or("", 3, command), texts.length(command), cwd, false, yield_time, false]
  first_snapshot <- ProcessHost.start(&first_launch)
  let typed_first: FixtureSnapshot = first_snapshot
  let [_, first_output, first_state] = typed_first
  let [_, _, _, sandbox_denied] = first_state

  if sandbox_denied {
    let decision: FixtureRetryDecision = plan_sandbox_retry(policy, sandbox, true, true, false, false, first_output)

    if let `RetrySandbox retry = decision {
      let [sandbox_requested, needs_approval, _] = retry

      if !(sandbox_requested) && !(needs_approval) {
        let retry_launch: FixtureLaunch = [texts.nth_or("", 0, command), texts.nth_or("", 1, command), texts.nth_or("", 2, command), texts.nth_or("", 3, command), texts.length(command), cwd, false, yield_time, true]
        retry_snapshot <- ProcessHost.start(&retry_launch)
        let typed_retry: FixtureSnapshot = retry_snapshot
        let [_, _, retry_state] = typed_retry

        if process_succeeded(retry_state) {
          score = score + 1
        }
      }
    }
  }
}

return { .score = score }
