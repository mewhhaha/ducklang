module () where

const { list } = import "duck:prelude/functional" ()
const { parse_cli } = import "./cli.duck" ()
const {} = import "./cli_types.duck" ()

type FixtureArgs = CodexCliArgs
type FixturePlan = CodexCliPlan

const args = comptime list(Text)
let input: FixtureArgs = args.prepend("remote-control", args.prepend("stop", args.singleton("--json")))
let plan: FixturePlan = parse_cli(input)
let score = 0

if let `ManageApplication command = plan {
  if let `RunRemoteControl options = command {
    if let `RemoteControlStop () = options.operation {
      if options.json { score = 1 }
    }
  }
}

return { .score = score }
