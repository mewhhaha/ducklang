module () where

const { parse_cli } = import "./cli.duck" ()
const {} = import "./cli_types.duck" ()

type FixtureArgs = CodexCliArgs
type FixtureNode = ListNode Text
type FixturePlan = CodexCliPlan

let empty: FixtureArgs = `Nil ()
let status_node: FixtureNode = ["status", empty]
let status_args: FixtureArgs = `Cons status_node
let login_node: FixtureNode = ["login", status_args]
let input: FixtureArgs = `Cons login_node
let plan: FixturePlan = parse_cli(input)
let score = 0

if let `Authenticate action = plan {
  if let `LoginStatus () = action { score = 1 }
}

return { .score = score }
