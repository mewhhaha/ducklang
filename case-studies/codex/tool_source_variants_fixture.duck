const { text_append } = import "duck:prelude/functional" ()
const { tool_source_definitions } = import "./tool_source_plan.duck" ()
const {} = import "./tool_source_types.duck" ()

type FixtureFacts = ToolSourceFacts
type FixtureDefinitions = ToolSourceDefinitions

let facts: FixtureFacts = [
  .guardian_reviewer = false,
  .environment = `NoEnvironment (),
  .shell = `DisabledShell (),
  .has_mcp_servers = false,
  .deferred_executor = false,
  .request_user_input = false,
  .request_permissions = true,
  .token_budget = false,
  .current_time = false,
  .sleep_tool = true,
  .plugin_install = `RecommendPluginInstall (),
  .apply_patch = true,
  .test_sync = false,
  .collaboration = `CollaborationV2 (),
  .collaboration_direct_model_only = false,
  .namespace_tools = false,
  .collaboration_namespace = "collaboration",
  .tool_search = false,
  .agent_jobs = false,
  .agent_job_worker = false]

let configured_runtimes: FixtureDefinitions = `Nil ()
let extension_runtimes: FixtureDefinitions = `Nil ()
let dynamic_runtimes: FixtureDefinitions = `Nil ()
let current = tool_source_definitions(facts, configured_runtimes, extension_runtimes, dynamic_runtimes)
let trace = ""
let count = 0
let direct_model_only_count = 0
let done = false

loop {
  if let `Cons node = current {
    let [definition, tail] = node
    let [[namespace, local_name], exposure, _, _, _, _] = definition
    trace = text_append [text_append [text_append [text_append [trace, namespace], "."], local_name], "|"]
    if let `DirectModelOnly () = exposure {
      direct_model_only_count = direct_model_only_count + 1
    }
    count = count + 1
    current = tail
  } else {
    done = true
  }

  if done { break }
}

let expected = ".update_plan|.request_plugin_install|.spawn_agent|.send_message|.followup_task|.wait_agent|.interrupt_agent|.list_agents|"
let score = 0
if trace == expected { score = score + 1 }
if count == 8 { score = score + 10 }
if direct_model_only_count == 0 { score = score + 100 }
return { .score = score }
