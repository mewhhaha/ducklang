module () where

const { text_append, text_starts_with } = import "duck:prelude/functional" ()
const {} = import "./cli_types.duck" ()

type AuthArgs = CodexCliArgs
type AuthTextOption = CodexCliTextOption
type AuthDeviceOptions = CodexDeviceLoginOptions
type AuthAction = CodexLoginAction
type AuthActionResult = CodexLoginActionResult
type AuthLogoutResult = CodexLogoutResult

type AuthFacts = CodexLoginFacts

type AuthFactsResult = Result Text AuthFacts

let rec scan_login_options_from: [AuthArgs, AuthFacts] -> AuthFactsResult = (args: AuthArgs, facts: AuthFacts) => {
  if let `Cons node = args {
    let [argument, tail] = node
    if argument == "--with-api-key" {
      scan_login_options_from(tail, facts :+ { .with_api_key = true })
    } else if argument == "--with-access-token" {
      scan_login_options_from(tail, facts :+ { .with_access_token = true })
    } else if argument == "--device-auth" {
      scan_login_options_from(tail, facts :+ { .device_auth = true })
    } else if argument == "--api-key" {
      if let `Cons value_node = tail {
        let [value, remaining] = value_node
        if text_starts_with(value, "-") {
          scan_login_options_from(tail, facts :+ { .deprecated_api_key = true })
        } else {
          scan_login_options_from(remaining, facts :+ { .deprecated_api_key = true })
        }
      } else {
        scan_login_options_from(tail, facts :+ { .deprecated_api_key = true })
      }
    } else if argument == "--experimental_issuer" {
      if let `Cons value_node = tail {
        let [value, remaining] = value_node
        scan_login_options_from(remaining, facts :+ { .issuer_base_url = `Some value })
      } else {
        `Err "missing value for --experimental_issuer"
      }
    } else if argument == "--experimental-client-id" {
      if let `Cons value_node = tail {
        let [value, remaining] = value_node
        scan_login_options_from(remaining, facts :+ { .client_id = `Some value })
      } else {
        `Err "missing value for --experimental-client-id"
      }
    } else if argument == "status" {
      if facts.status {
        `Err "login status was specified more than once"
      } else {
        scan_login_options_from(tail, facts :+ { .status = true })
      }
    } else {
      `Err (text_append("unknown login argument: ", argument))
    }
  } else {
    `Ok facts
  }
}

let parse_login_options: AuthArgs -> AuthActionResult = (args: AuthArgs) => {
  let initial: AuthFacts = [.with_api_key = false, .with_access_token = false, .device_auth = false, .deprecated_api_key = false, .status = false, .issuer_base_url = `None (), .client_id = `None ()]
  let parsed: AuthFactsResult = scan_login_options_from(args, initial)
  if let `Err message = parsed {
    `Err message
  } else if let `Ok facts = parsed {
    if facts.status {
      `Ok (`LoginStatus ())
    } else if facts.with_api_key && facts.with_access_token {
      `Err "Choose one login credential source: --with-api-key or --with-access-token."
    } else if facts.device_auth {
      let options: AuthDeviceOptions = [.issuer_base_url = facts.issuer_base_url, .client_id = facts.client_id]
      `Ok (`DeviceLogin options)
    } else if facts.deprecated_api_key {
      `Err "The --api-key flag is no longer supported. Pipe the key with --with-api-key."
    } else if facts.with_api_key {
      `Ok (`ApiKeyLogin ())
    } else if facts.with_access_token {
      `Ok (`AccessTokenLogin ())
    } else {
      `Ok (`BrowserLogin ())
    }
  } else {
    `Err "login option scanner returned an unknown result"
  }
}

const parse_logout_options: AuthArgs -> AuthLogoutResult = (args: AuthArgs) => {
  if let `Nil () = args {
    `Ok ()
  } else {
    `Err "logout does not accept arguments"
  }
}

return {
  parse_login_options,
  parse_logout_options,
}
