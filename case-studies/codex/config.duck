module () where

const { .json_object, .json_object_empty, .merge_json } = import "duck:prelude/json" ();
const { .list, .path_parent, .text_append, .text_starts_with } = import "duck:prelude/functional" ();
const config_types_module = import "./config_types.duck";

type LayerTextOption = ConfigTextOption
type LayerJsonOption = ConfigJsonOption
type LayerSource = ConfigLayerSource
type Layer = ConfigLayer
type Layers = ConfigLayers
type LayerValidation = ConfigValidation
type LayerJson = Json

const layers = comptime list Layer;

const layer_precedence = (source: LayerSource) => if let `Mdm _ = source {
  0
} else if let `System _ = source {
  10
} else if let `EnterpriseManaged _ = source {
  15
} else if let `User user = source {
  let [_, profile] = user;

  if let `Some _ = profile { 21 } else { 20 }
} else if let `Project _ = source {
  25
} else if let `SessionFlags () = source {
  30
} else if let `LegacyFile _ = source {
  40
} else {
  50
};

const layer_is_disabled = (layer: Layer) => {
  let [_, _, reason] = layer;

  if let `Some _ = reason { true } else { false }
};

const project_folder: LayerSource -> LayerTextOption = (source) => if let `Project folder = source {
  `Some folder
} else {
  `None ()
};

const path_is_strict_descendant = (path: Text, ancestor: Text) => {
  if path == ancestor {
    false
  } else if ancestor == "/" {
    text_starts_with [path, "/"]
  } else {
    text_starts_with [path, text_append [ancestor, "/"]]
  }
};

const validate_layer_order: Layers -> LayerValidation = (values) => {
  let current = values;
  let previous_precedence = -1;
  let previous_project: LayerTextOption = `None ();
  let validation: LayerValidation = `Valid ();
  let done = false;

  loop {
    if let `Cons node = current {
      let [layer, tail] = node;
      let [source, _, _] = layer;
      let precedence = layer_precedence source;

      if precedence < previous_precedence {
        validation = `Invalid ("Config layers are not in precedence order")
        done = true
      } else {
        let folder = project_folder source;

        if let `Some current_folder = folder {
          if let `Some previous_folder = previous_project {
            let previous_root = path_parent previous_folder;

            if path_is_strict_descendant(current_folder, previous_root) {
              previous_project = `Some current_folder
            } else {
              validation = `Invalid ("Project config layers are not ordered from root to cwd")
              done = true
            }
          } else {
            previous_project = `Some current_folder
          }
        }

        previous_precedence = precedence
        current = tail
      }
    } else {
      done = true
    }

    if done {
      break;
    }
  }

  validation
};

const effective_config = (values: Layers) => {
  let current = values;
  let effective: LayerJson = json_object(json_object_empty());
  let done = false;

  loop {
    if let `Cons node = current {
      let [layer, tail] = node;
      let [_, config, _] = layer;

      if layer_is_disabled layer {
        ()
      } else {
        effective = merge_json(effective, config)
      }

      current = tail
    } else {
      done = true
    }

    if done {
      break;
    }
  }

  effective
};

const effective_user_config: Layers -> LayerJsonOption = (values) => {
  let current = values;
  let effective: LayerJson = json_object(json_object_empty());
  let found = false;
  let done = false;

  loop {
    if let `Cons node = current {
      let [layer, tail] = node;
      let [source, config, _] = layer;

      if layer_is_disabled layer {
        ()
      } else if let `User _ = source {
        effective = merge_json(effective, config)
        found = true
      }

      current = tail
    } else {
      done = true
    }

    if done {
      break;
    }
  }

  if found {
    `Some effective
  } else {
    `None ()
  }
};

const active_user_file: Layers -> LayerTextOption = (values) => {
  let current = values;
  let file: LayerTextOption = `None ();
  let done = false;

  loop {
    if let `Cons node = current {
      let [layer, tail] = node;
      let [source, _, _] = layer;

      if layer_is_disabled layer {
        ()
      } else if let `User user = source {
        let [path, _] = user;
        file = `Some path
      }

      current = tail
    } else {
      done = true
    }

    if done {
      break;
    }
  }

  file
};

return {
  .layer_precedence,
  .layer_is_disabled,
  .validate_layer_order,
  .effective_config,
  .effective_user_config,
  .active_user_file,
};
