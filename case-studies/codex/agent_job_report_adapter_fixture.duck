module (!init: Init) where

const {} = import "./agent_job_report_types.duck" ()
const { plan_report_agent_job_result } = import "./agent_job_report_call.duck" ()
const { run_report_agent_job_result } = import "./agent_job_report_execution.duck" ()

let score = 0
let accepted = plan_report_agent_job_result(`Function "{\"job_id\":\"job-1\",\"item_id\":\"row-1\",\"result\":{\"answer\":42},\"stop\":true}")
if let `RecordResult args = accepted {
  let result = run_report_agent_job_result args
  if let `Completed output = result {
    if output == "{\"accepted\":true}" { score = score + 1 }
  }
}

let rejected = plan_report_agent_job_result(`Function "{\"job_id\":\"job-1\",\"item_id\":\"row-2\",\"result\":{}}")
if let `RecordResult args = rejected {
  let result = run_report_agent_job_result args
  if let `Completed output = result {
    if output == "{\"accepted\":false}" { score = score + 10 }
  }
}

return { .score = score }
