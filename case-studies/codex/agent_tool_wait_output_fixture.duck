module () where

const {} = import "./agent_tool_types.duck" ();
const { .render_wait_agent_output } = import "./agent_tool_wait_output.duck" ();

type FixtureMailbox = AgentToolMailboxSnapshot

let timeout: FixtureMailbox = [.updated_count = 0, .steered = false, .timed_out = true];
let score = 0;
if render_wait_agent_output timeout == "{\"message\":\"Wait timed out.\",\"timed_out\":true}" {
  score = 1 }

return { .score = score };
