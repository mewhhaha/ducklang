module () where

const { parse_json_document } = import "duck:prelude/json" ()
const { format_i32 } = import "duck:prelude/numeric" ()
const { text_append } = import "duck:prelude/runtime" ()
const {} = import "./view_image_types.duck" ()
const { decode_view_image_value, view_image_parse_failure } = import "./view_image_value.duck" ()

type ImageJsonParseResult = ViewImageParseResult

let parse_view_image_args: Text -> ImageJsonParseResult = document => {
  let parsed = parse_json_document document
  if let `Ok value_and_position = parsed {
    let [value, _] = value_and_position
    decode_view_image_value value
  } else if let `Err error = parsed {
    let [position, message] = error
    view_image_parse_failure(text_append([message, text_append([" at byte ", format_i32(position)])]))
  } else {
    view_image_parse_failure "invalid JSON parse result"
  }
}

return { parse_view_image_args }
