module () where

const { .list } = import "duck:prelude/functional" ();
const hook_types_module = import "./hook_types.duck";
const hook_command_module = import "./hook_command.duck";
const { .evaluate_hook_command } = hook_command_module();

type FixtureResult = HookCommandResult
type FixtureEntry = HookOutputEntry
type FixtureEntries = HookOutputEntries

const fixture_entries = comptime list FixtureEntry;

let result: FixtureResult = [`None (), `Some 9, "ignored", " cleanup failed "];
let [status, output_entries, _, _, _, _, _] = evaluate_hook_command(`SessionEnd (), result);
let score: I32 = 0;

if let `Failed () = status {
  let [_, message] = fixture_entries.nth_or([`Error (), ""], 0, output_entries);
  if message == "cleanup failed" { score = 1 }
}

return { .score = score };
