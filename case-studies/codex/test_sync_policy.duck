module () where

const { .text_append } = import "duck:prelude/runtime" ();
const {} = import "./test_sync_types.duck" ();

type SyncPolicyArgs = TestSyncArgs
type SyncPolicyBarrierResult = TestSyncBarrierHostResult
type SyncPolicyExecutionResult = TestSyncExecutionResult
type SyncPolicyPlan = TestSyncPlan

const plan_test_sync: SyncPolicyArgs -> SyncPolicyPlan = args => {
  if let `SyncBarrierPresent barrier = args.barrier {
    if barrier.participants == "0" {
      `RejectRequest "barrier participants must be greater than zero"
    } else if barrier.timeout_ms == "0" {
      `RejectRequest "barrier timeout must be greater than zero"
    } else {
      `RunSync args
    }
  } else {
    `RunSync args
  }
};

const finish_test_sync_barrier: [Text, SyncPolicyBarrierResult] -> SyncPolicyExecutionResult = (
  barrier_id: Text,
  result: SyncPolicyBarrierResult,
) => {
  if let `Released () = result {
    `Completed "ok"
  } else if let `ParticipantsMismatch existing = result {
    `Rejected (
      text_append [
        "barrier ",
        text_append [
          barrier_id,
          text_append [" already registered with ", text_append [existing, " participants"]],
        ],
      ]
    )
  } else {
    `Rejected "test_sync_tool barrier wait timed out"
  }
};

return {
  .finish_test_sync_barrier,
  .plan_test_sync,
};
