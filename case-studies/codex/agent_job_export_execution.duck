module (!init: Init) where

const {} = import "./agent_job_export_types.duck" ();
const { .render_agent_job_csv } = import "./agent_job_csv_output.duck" ();

type AgentJobExportCompletion = AgentJobRunCompletion
type AgentJobExportOutcome = AgentJobCsvWriteOutcome
type AgentJobExportRequest = AgentJobCsvWriteRequest
type AgentJobExportResult = AgentJobExportExecutionResult

let run_agent_job_export = (completed: AgentJobExportCompletion) => {
  let rendered = render_agent_job_csv completed;
  if let `CsvExportFailed reason = rendered {
    let result: AgentJobExportResult = `Rejected reason;
    result
  } else if let `CsvExported content = rendered {
    let request: AgentJobExportRequest = [.output_path = completed.output_path, .content = content];
    written <- AgentJobExportHost.write(&request)
    let outcome: AgentJobExportOutcome = written;
    if let `CsvWritten () = outcome {
      let result: AgentJobExportResult = `Completed completed.output_path;
      result
    } else if let `CsvWriteFailed reason = outcome {
      let result: AgentJobExportResult = `Rejected reason;
      result
    } else {
      let result: AgentJobExportResult = `Rejected "agent job export host returned no write outcome";
      result
    }
  } else {
    let result: AgentJobExportResult = `Rejected "agent job csv renderer returned no result";
    result
  }
};

return { .run_agent_job_export };
