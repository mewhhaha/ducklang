module () where

const hook_output_types_module = import "./hook_output_types.duck";
const hook_output_module = import "./hook_output.duck";
const { .parse_context_output } = hook_output_module();

type FixtureContextParse = HookContextParse

let parsed: FixtureContextParse = parse_context_output(
  "SessionStart",
  "{\"continue\":false,\"stopReason\":\"pause\",\"systemMessage\":\"warn\",\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"remember\"}}",
);
let score = 0;

if let `ContextOk output = parsed {
  let [universal, additional_context] = output;
  let [continue_processing, stop_reason, _, system_message] = universal;

  if continue_processing {
    ()
  } else {
    score = score * 10 + 1
  }

  if let `Some reason = stop_reason {
    if reason == "pause" { score = score * 10 + 1 }
  }

  if let `Some context = additional_context {
    if context == "remember" { score = score * 10 + 1 }
  }

  if let `Some message = system_message {
    if message == "warn" { score = score * 10 + 1 }
  }
}

return { .score = score };
