module () where

const { .text_append } = import "duck:prelude/runtime" ();

const request_user_input_tool_description: Bool -> Text = default_mode_enabled => {
  let modes = if default_mode_enabled { "Default or Plan mode" } else { "Plan mode" };
  text_append(
    "Request user input for one to three short questions and wait for the response. Set autoResolutionMs, from 60000 to 240000 milliseconds, only when the question is useful but non-blocking and continuing with best judgment is acceptable if the user does not answer; omit it when explicit user input is required. This tool is only available in ",
    text_append(modes, "."),
  )
};

return { .request_user_input_tool_description };
