module () where

const { encode_json } = import "duck:prelude/json/encode" ()
const { json_bool, json_object, json_object_empty, json_object_prepend, json_string } = import "duck:prelude/json/values" ()
const {} = import "./agent_tool_types.duck" ()

const render_wait_agent_output: AgentToolMailboxSnapshot -> Text = snapshot => {
  let message = "Wait completed."
  if snapshot.timed_out {
    message = "Wait timed out."
  } else if snapshot.steered {
    message = "Wait interrupted by new input."
  }
  encode_json(json_object(json_object_prepend("message", json_string message, json_object_prepend("timed_out", json_bool snapshot.timed_out, json_object_empty()))))
}

return { render_wait_agent_output }
