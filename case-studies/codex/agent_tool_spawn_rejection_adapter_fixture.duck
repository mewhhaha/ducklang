module (!init: Init) where

const {} = import "./agent_tool_types.duck" ()
const { plan_spawn_agent_call } = import "./agent_tool_spawn_call.duck" ()
const { run_spawn_agent } = import "./agent_tool_spawn_execution.duck" ()

type FixtureContext = AgentToolContext
type FixturePlan = AgentToolPlan
type FixtureSpawnArguments = AgentToolSpawnArguments

let context: FixtureContext = [.v2_enabled = true, .current_path = "/root", .current_depth = 0, .maximum_depth = 2, .source = `Root (), .active_turn = true, .active_agents = 1, .maximum_threads = 4]
let arguments: FixtureSpawnArguments = [.task_name = "reviewer", .message = "inspect the compiler", .fork_turns = `None (), .model = `Some "missing", .reasoning_effort = `None ()]
let plan: FixturePlan = plan_spawn_agent_call(context, arguments)
let score = 0
if let `SpawnAgentPlanned request = plan {
  let output = run_spawn_agent("call-rejected-spawn", request, [.hide_metadata = false])
  if output == "Unknown model `missing` for spawn_agent. Available models: gpt-5.6" { score = 1 }
}

return { .score = score }
