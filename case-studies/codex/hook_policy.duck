module () where

const { format_i32, list, text_append, text_trim_ascii_whitespace } = import "duck:prelude/functional" ()
const hook_types_module = import "./hook_types.duck"

type PolicyI32Option = HookI32Option
type PolicyTextOption = HookTextOption
type PolicyTexts = HookTexts
type PolicyEvent = HookEvent
type PolicyScope = HookScope
type PolicySource = HookSource
type PolicyMatcher = HookMatcher
type PolicyHandlerConfig = HookHandlerConfig
type PolicyConfiguredHandler = HookConfiguredHandler
type PolicyStateOption = HookStateOption
type PolicyTrustStatus = HookTrustStatus
type PolicyPermissionDecisions = HookPermissionDecisions
type PolicyPermissionDecisionOption = HookPermissionDecisionOption
type PolicyLegacyResults = HookLegacyResults
type PolicyLegacyOutcome = HookLegacyOutcome

const texts = comptime list(Text)
const append_text = (left: Text, right: Text) => text_append([left, right])

const hook_event_key_label = (event: PolicyEvent) => {
  if let `PreToolUse () = event {
    "pre_tool_use"
  } else if let `PermissionRequest () = event {
    "permission_request"
  } else if let `PostToolUse () = event {
    "post_tool_use"
  } else if let `PreCompact () = event {
    "pre_compact"
  } else if let `PostCompact () = event {
    "post_compact"
  } else if let `SessionStart () = event {
    "session_start"
  } else if let `SessionEnd () = event {
    "session_end"
  } else if let `UserPromptSubmit () = event {
    "user_prompt_submit"
  } else if let `SubagentStart () = event {
    "subagent_start"
  } else if let `SubagentStop () = event {
    "subagent_stop"
  } else {
    "stop"
  }
}

const hook_key = (key_source: Text, event: PolicyEvent, group_index: I32, handler_index: I32) => {
  append_text(key_source, append_text(":", append_text(hook_event_key_label(event), append_text(":", append_text(format_i32(group_index), append_text(":", format_i32(handler_index)))))))
}

const hook_scope = (event: PolicyEvent) => {
  if let `SessionStart () = event {
    `Thread ()
  } else if let `SessionEnd () = event {
    `Thread ()
  } else if let `SubagentStart () = event {
    `Thread ()
  } else {
    `Turn ()
  }
}

const event_uses_matcher = (event: PolicyEvent) => {
  if let `UserPromptSubmit () = event {
    false
  } else if let `Stop () = event {
    false
  } else {
    true
  }
}

const normalize_timeout = (event: PolicyEvent, configured: PolicyI32Option) => {
  if let `SessionEnd () = event {
    let timeout = if let `Some seconds = configured { seconds } else { 1 }

    if timeout < 1 {
      1
    } else if timeout > 3 {
      3
    } else {
      timeout
    }
  } else {
    let timeout = if let `Some seconds = configured { seconds } else { 600 }
    if timeout < 1 { 1 } else { timeout }
  }
}

const normalize_hook_handler = (event: PolicyEvent, matcher: PolicyMatcher, config: PolicyHandlerConfig, source_path: Text, source: PolicySource, display_order: I32) => {
  if let `Prompt () = config {
    `Skipped (append_text("skipping prompt hook in ", append_text(source_path, ": prompt hooks are not supported yet")))
  } else if let `Agent () = config {
    `Skipped (append_text("skipping agent hook in ", append_text(source_path, ": agent hooks are not supported yet")))
  } else if let `Command command_config = config {
    let [command, timeout, asynchronous, status_message] = command_config

    if text_trim_ascii_whitespace(command) == "" {
      `Skipped (append_text("skipping empty hook command in ", source_path))
    } else if asynchronous {
      if let `SessionEnd () = event {
        let configured: PolicyConfiguredHandler = [event, matcher, command, normalize_timeout(event, timeout), status_message, source_path, source, display_order]
        `Configured ([configured, texts.singleton(append_text("running async SessionEnd hook synchronously in ", source_path))])
      } else {
        `Skipped (append_text("skipping async hook in ", append_text(source_path, ": async hooks are not supported yet")))
      }
    } else {
      let warnings: PolicyTexts = texts.empty()
      let normalized_timeout = normalize_timeout(event, timeout)

      if let `SessionEnd () = event {
        if let `Some configured_timeout = timeout {
          if configured_timeout > 3 {
            warnings = texts.singleton(append_text("clamping SessionEnd hook timeout to 3s in ", source_path))
          }
        }
      }

      let configured: PolicyConfiguredHandler = [event, matcher, command, normalized_timeout, status_message, source_path, source, display_order]
      `Configured ([configured, warnings])
    }
  } else {
    `Skipped "invalid hook handler configuration"
  }
}

const hook_enabled = (managed: Bool, state: PolicyStateOption) => {
  if managed {
    true
  } else if let `PresentHookState configured_state = state {
    let [enabled, _] = configured_state
    if let `Disabled () = enabled { false } else { true }
  } else {
    true
  }
}

const hook_trust_status = (managed: Bool, current_hash: Text, state: PolicyStateOption) => {
  if managed {
    `Managed ()
  } else if let `PresentHookState configured_state = state {
    let [_, trusted_hash] = configured_state

    if let `TrustedHash hash = trusted_hash {
      if hash == current_hash { `Trusted () } else { `Modified () }
    } else {
      `Untrusted ()
    }
  } else {
    `Untrusted ()
  }
}

const hook_may_run = (managed: Bool, bypass_trust: Bool, current_hash: Text, state: PolicyStateOption) => {
  if hook_enabled(managed, state) {
    if bypass_trust {
      true
    } else {
      let status: PolicyTrustStatus = hook_trust_status(managed, current_hash, state)

      if let `Managed () = status {
        true
      } else if let `Trusted () = status {
        true
      } else {
        false
      }
    }
  } else {
    false
  }
}

const resolve_permission_decisions: PolicyPermissionDecisions -> PolicyPermissionDecisionOption = decisions => {
  let current = decisions
  let resolved: PolicyPermissionDecisionOption = `None ()
  let saw_allow = false

  loop {
    if let `Cons node = current {
      let [decision, tail] = node

      if let `Deny message = decision {
        resolved = `Some (`Deny message)
        break
      } else {
        saw_allow = true
        current = tail
      }
    } else {
      break
    }
  }

  if let `Some value = resolved {
    `Some value
  } else if saw_allow {
    `Some (`Allow ())
  } else {
    `None ()
  }
}

const fold_legacy_hook_results: PolicyLegacyResults -> PolicyLegacyOutcome = results => {
  let current = results
  let continued = true
  let messages: Text = ""
  let message_count = 0

  loop {
    if let `Cons node = current {
      let [result, tail] = node
      let message: PolicyTextOption = `None ()

      if let `FailedAbort failure = result {
        message = `Some failure
        continued = false
      } else if let `FailedContinue failure = result {
        message = `Some failure
      }

      if let `Some value = message {
        if message_count > 0 {
          messages = append_text(messages, "\n\n")
        }

        messages = append_text(messages, value)
        message_count = message_count + 1
      }

      if continued {
        current = tail
      } else {
        break
      }
    } else {
      break
    }
  }

  [continued, messages, message_count]
}

return {
  hook_event_key_label,
  hook_key,
  hook_scope,
  event_uses_matcher,
  normalize_timeout,
  normalize_hook_handler,
  hook_enabled,
  hook_trust_status,
  hook_may_run,
  resolve_permission_decisions,
  fold_legacy_hook_results,
}
