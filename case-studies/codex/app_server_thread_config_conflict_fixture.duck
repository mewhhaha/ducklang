module () where

const { json_object, json_object_empty, json_object_prepend, json_string } = import "duck:prelude/json" ()
const { decode_thread_start } = import "./app_server_thread_methods.duck" ()
const {} = import "./app_server_types.duck" ()

type FixtureResult = AppServerMethodDecodeResult

let fields = json_object_empty()
fields = json_object_prepend("permissions", json_string("workspace"), fields)
fields = json_object_prepend("sandbox", json_string("workspaceWrite"), fields)
let decoded: FixtureResult = decode_thread_start(json_object(fields))
let score = if let `MethodError message = decoded {
  if message == "`permissions` cannot be combined with `sandbox`" { 1 } else { 0 }
} else { 0 }

return { .score = score }
