module () where

const mcp_types_module = import "./mcp_types.duck"
const mcp_module = import "./mcp.duck"
const { normalize_mcp_approval_decision, requires_mcp_tool_approval } = mcp_module()

type FixtureBoolOption = McpBoolOption
type FixtureAnnotations = McpToolAnnotations
type FixtureMode = McpApprovalMode
type FixtureDecision = McpApprovalDecision

let yes: FixtureBoolOption = `Some true
let no: FixtureBoolOption = `Some false
let missing: FixtureBoolOption = `None ()
let auto: FixtureMode = `Auto ()
let writes: FixtureMode = `Writes ()
let prompt: FixtureMode = `Prompt ()
let read_only: FixtureAnnotations = [yes, missing, missing]
let destructive: FixtureAnnotations = [yes, yes, missing]
let writable: FixtureAnnotations = [no, no, no]
let score = 0

if !(requires_mcp_tool_approval(read_only, auto, false)) {
  score = score + 1
}

if requires_mcp_tool_approval(destructive, auto, false) {
  score = score + 1
}

if requires_mcp_tool_approval(writable, writes, false) && !(requires_mcp_tool_approval(read_only, writes, false)) {
  score = score + 1
}

if !(requires_mcp_tool_approval(writable, prompt, true)) {
  score = score + 1
}

let remembered: FixtureDecision = `AcceptAndRemember ()
let normalized: FixtureDecision = normalize_mcp_approval_decision(remembered, prompt)
if let `Accept () = normalized {
  score = score + 1
}

return { .score = score }
