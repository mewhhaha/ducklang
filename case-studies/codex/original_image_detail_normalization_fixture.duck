module () where

const {} = import "./original_image_detail_types.duck" ();
const original_image_detail_module = import "./original_image_detail.duck";
const { .can_request_original_image_detail, .normalize_output_image_detail } =
  original_image_detail_module();

type FixtureDetail = OutputImageDetail
type FixtureDetailOption = OutputImageDetailOption

let score = 0;
let original: FixtureDetail = `Original ();
let original_detail: FixtureDetailOption = `Some original;
let low: FixtureDetail = `Low ();
let low_detail: FixtureDetailOption = `Some low;
let absent: FixtureDetailOption = `None ();

if can_request_original_image_detail true && !(can_request_original_image_detail false) {
  score = score + 1
}

if let `Some selected = normalize_output_image_detail(true, original_detail) {
  if let `Original () = selected { score = score + 10 }
}

if let `None () = normalize_output_image_detail(false, original_detail) {
  score = score + 100
}

if let `Some selected = normalize_output_image_detail(false, low_detail) {
  if let `Low () = selected { score = score + 1000 }
}

if let `None () = normalize_output_image_detail(true, absent) {
  score = score + 10000
}

return { .score = score };
