module () where

const agent_types_module = import "./agent_types.duck";
const { .agent_status_json } = import "./agent_status_json.duck" ();
const { .text_append } = import "duck:prelude/runtime" ();

const render_interrupt_agent_output: AgentStatus -> Text = status => {
  text_append ["{\"previous_status\":", text_append [agent_status_json status, "}"]]
};

return { .render_interrupt_agent_output };
