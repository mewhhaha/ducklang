module () where

const {} = import "./tool_types.duck" ()
const { current_time_tool_definitions } = import "./current_time_tool_registration.duck" ()

type FixtureDefinitions = ToolDefinitions

let definitions: FixtureDefinitions = current_time_tool_definitions(true, true)
let score = 0
if let `Cons current_node = definitions {
  let [_, sleep_tail] = current_node
  if let `Cons sleep_node = sleep_tail {
    let [definition, tail] = sleep_node
    let [name, _, tool_handler, _, supports_parallel, waits_for_cancellation] = definition
    let [namespace, local_name] = name
    if namespace == "clock" && local_name == "sleep" && !(supports_parallel) && !(waits_for_cancellation) {
      if let `Sleep () = tool_handler {
        if let `Nil () = tail { score = 1 }
      }
    }
  }
}

return { .score = score }
