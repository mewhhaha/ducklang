module () where

type ConfigTextOption = Option Text
type ConfigJsonOption = Option Json
type ConfigMdmSource = [Text, Text]
type ConfigEnterpriseSource = [Text, Text]
type ConfigUserSource = [Text, ConfigTextOption]
type ConfigLayerSource =
  | `Mdm ConfigMdmSource
  | `System Text
  | `EnterpriseManaged ConfigEnterpriseSource
  | `User ConfigUserSource
  | `Project Text
  | `SessionFlags Unit
  | `LegacyFile Text
  | `LegacyMdm Unit
type ConfigLayer = [ConfigLayerSource, Json, ConfigTextOption]
type ConfigLayers = List ConfigLayer
type ConfigValidation =
  | `Valid Unit
  | `Invalid Text

return {}
