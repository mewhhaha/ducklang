module (!init: Init) where

const {} = import "./test_sync_types.duck" ()
const { finish_test_sync_barrier } = import "./test_sync_policy.duck" ()

type SyncExecutionArgs = TestSyncArgs
type SyncExecutionResult = TestSyncExecutionResult
type SyncExecutionBarrierResult = TestSyncBarrierHostResult

let run_test_sync = (args: SyncExecutionArgs) => {
  if let `SyncDurationPresent duration = args.sleep_before_ms {
    if duration != "0" { _ <- TestSyncHost.sleep(&duration) }
  }

  let result: SyncExecutionResult = `Completed "ok"
  let continue_after_barrier = true
  if let `SyncBarrierPresent barrier = args.barrier {
    host_result <- TestSyncHost.barrier(&barrier)
    let barrier_result: SyncExecutionBarrierResult = host_result
    result = finish_test_sync_barrier(barrier.id, barrier_result)
    if let `Rejected _ = result { continue_after_barrier = false }
  }

  if continue_after_barrier {
    if let `SyncDurationPresent duration = args.sleep_after_ms {
      if duration != "0" { _ <- TestSyncHost.sleep(&duration) }
    }
  }

  result
}

return { run_test_sync }
