module () where

const {} = import "./original_image_detail_types.duck" ();

type ImagePolicyDetail = OutputImageDetail
type ImagePolicyDetailOption = OutputImageDetailOption
type ImagePolicyItem = FunctionOutputContentItem
type ImagePolicyItemNode = FunctionOutputContentItemNode
type ImagePolicyItems = FunctionOutputContentItems

const can_request_original_image_detail: Bool -> Bool = supported => {
  if supported { true } else { false }
};

const normalize_output_image_detail: [Bool, ImagePolicyDetailOption] -> ImagePolicyDetailOption = (
  supported,
  detail,
) => {
  if let `Some selected = detail {
    if let `Original () = selected {
      if supported { detail } else { `None () }
    } else {
      detail
    }
  } else {
    `None ()
  }
};

const sanitize_output_item: [Bool, ImagePolicyItem] -> ImagePolicyItem = (supported, item) => {
  if supported {
    item
  } else if let `InputImage image = item {
    let [image_url, detail] = image;

    if let `Some selected = detail {
      if let `Original () = selected {
        let fallback: ImagePolicyDetail = `High ();
        let fallback_detail: ImagePolicyDetailOption = `Some fallback;
        let sanitized: ImagePolicyItem = `InputImage ([image_url, fallback_detail]);
        sanitized
      } else {
        item
      }
    } else {
      item
    }
  } else {
    item
  }
};

const sanitize_original_image_detail: [Bool, ImagePolicyItems] -> ImagePolicyItems = (
  supported,
  items,
) => {
  if supported {
    items
  } else {
    let current = items;
    let reversed: ImagePolicyItems = `Nil ();
    let done = false;

    loop {
      if let `Cons node = current {
        let [item, tail] = node;
        let sanitized_node: ImagePolicyItemNode = [sanitize_output_item(false, item), reversed];
        reversed = `Cons sanitized_node
        current = tail
      } else {
        done = true
      }

      if done { break; }
    }

    let sanitized: ImagePolicyItems = `Nil ();
    done = false

    loop {
      if let `Cons node = reversed {
        let [item, tail] = node;
        let sanitized_node: ImagePolicyItemNode = [item, sanitized];
        sanitized = `Cons sanitized_node
        reversed = tail
      } else {
        done = true
      }

      if done { break; }
    }

    sanitized
  }
};

return {
  .can_request_original_image_detail,
  .normalize_output_image_detail,
  .sanitize_original_image_detail,
};
