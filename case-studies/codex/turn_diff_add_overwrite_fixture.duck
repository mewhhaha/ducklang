module () where

const {} = import "./turn_diff_types.duck" ();
const { .empty_turn_diff, .track_turn_diff_delta } = import "./turn_diff.duck" ();
const { .turn_diff_net_changes } = import "./turn_diff_projection.duck" ();
const { .turn_diff_fixture_exact_delta } = import "./turn_diff_fixture_common.duck" ();

type FixtureMutation = TurnDiffMutation
type FixtureFileMutation = TurnDiffFileMutation
type FixtureTextOption = TurnDiffTextOption
type FixtureAdd = TurnDiffAdd

const verify_turn_diff_add_overwrite_fixture: () -> I32 = () => {
  let overwritten: FixtureTextOption = `Some "before\n";
  let addition: FixtureAdd = [.content = "after\n", .overwritten_content = overwritten];
  let file_mutation: FixtureFileMutation = `TurnDiffAdd addition;
  let mutation: FixtureMutation = [.path = "existing.txt", .mutation = file_mutation];
  let state = track_turn_diff_delta(empty_turn_diff(), "", turn_diff_fixture_exact_delta mutation);

  let score = 0;
  let changes = turn_diff_net_changes state;
  if let `Cons node = changes {
    let [change, tail] = node;
    if let `TurnDiffUpdated updated = change {
      if updated.path.path == "existing.txt" && updated.old_content == "before\n" && updated.new_content == "after\n" {
        if let `Nil () = tail { score = score + 1 }
      }
    }
  }
  if state.next_revision == 2 {
    score = score + 10
  }
  score
};

return { .verify_turn_diff_add_overwrite_fixture };
