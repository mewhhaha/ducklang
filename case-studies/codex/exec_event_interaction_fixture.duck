module () where

const exec_types_module = import "./exec_types.duck"
const events_module = import "./exec_events.duck"
const { plan_terminal_interaction } = events_module()

type FixtureI32Option = ExecEventI32Option
type FixtureInteractionPlan = ExecInteractionPlan

let score = 0
let process_id: FixtureI32Option = `Some 1000
let empty_poll: FixtureInteractionPlan = plan_terminal_interaction("call-1", 1000, process_id, "")

if let `EmitInteraction event = empty_poll {
  let [call_id, interaction_process_id, stdin] = event
  if call_id == "call-1" && interaction_process_id == 1000 && stdin == "" { score = score + 1 }
}

if let `SuppressInteraction () = plan_terminal_interaction("call-1", 1000, `None (), "") {
  score = score + 1
}

let sent_input: FixtureInteractionPlan = plan_terminal_interaction("call-1", 1000, `None (), "yes\n")
if let `EmitInteraction event = sent_input {
  let [_, interaction_process_id, stdin] = event
  if interaction_process_id == 1000 && stdin == "yes\n" { score = score + 1 }
}

return { .score = score }
