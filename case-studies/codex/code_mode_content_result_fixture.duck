module () where

const {} = import "./code_mode_nested_tool_types.duck" ();
const { .code_mode_content_result } = import "./code_mode_result.duck" ();

type FixtureContent = FunctionOutputContentItem
type FixtureContentNode = FunctionOutputContentItemNode
type FixtureContents = FunctionOutputContentItems
type FixtureDetailOption = OutputImageDetailOption

let contents: FixtureContents = `Nil ();
let beta: FixtureContent = `InputText "beta";
let beta_node: FixtureContentNode = [beta, contents];
contents = `Cons beta_node
let unicode_blank: FixtureContent = `InputText "　";
let unicode_blank_node: FixtureContentNode = [unicode_blank, contents];
contents = `Cons unicode_blank_node
let encrypted: FixtureContent = `EncryptedContent "secret";
let encrypted_node: FixtureContentNode = [encrypted, contents];
contents = `Cons encrypted_node
let audio: FixtureContent = `InputAudio "audio://one";
let audio_node: FixtureContentNode = [audio, contents];
contents = `Cons audio_node
let no_detail: FixtureDetailOption = `None ();
let image: FixtureContent = `InputImage (["image://one", no_detail]);
let image_node: FixtureContentNode = [image, contents];
contents = `Cons image_node
let blank_image: FixtureContent = `InputImage (["  ", no_detail]);
let blank_image_node: FixtureContentNode = [blank_image, contents];
contents = `Cons blank_image_node
let alpha: FixtureContent = `InputText " alpha ";
let alpha_node: FixtureContentNode = [alpha, contents];
contents = `Cons alpha_node
let blank: FixtureContent = `InputText "\n\t";
let blank_node: FixtureContentNode = [blank, contents];
contents = `Cons blank_node

let score = 0;
if code_mode_content_result contents == " alpha \nimage://one\naudio://one\nbeta" {
  score = 1
}

return { .score = score };
