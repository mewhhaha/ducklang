module () where

const {} = import "./cli_types.duck" ()
const { classify_cli_head } = import "./cli_head.duck" ()
const { parse_completion_options, parse_feature_command } = import "./cli_options.duck" ()
const { parse_archive_options, parse_delete_options, parse_fork_options, parse_resume_options } = import "./cli_sessions.duck" ()
const { parse_login_options, parse_logout_options } = import "./cli_auth.duck" ()
const { parse_mcp_options } = import "./cli_mcp.duck" ()
const { parse_plugin_options } = import "./cli_plugin.duck" ()
const { parse_cloud_options } = import "./cli_cloud.duck" ()
const { parse_exec_server_options, parse_mcp_server_options, parse_stdio_to_uds_options } = import "./cli_server.duck" ()
const { parse_desktop_app_options, parse_remote_control_options } = import "./cli_app.duck" ()
const { parse_app_server_options } = import "./cli_app_server.duck" ()
const { parse_apply_options, parse_doctor_options, parse_responses_proxy_options } = import "./cli_utility.duck" ()
const { parse_debug_options } = import "./cli_debug.duck" ()
const { parse_execpolicy_options } = import "./cli_execpolicy.duck" ()
const { parse_sandbox_options } = import "./cli_sandbox.duck" ()

type CliArgs = CodexCliArgs
type CliPlan = CodexCliPlan
type CliCompletionResult = CodexCompletionOptionsResult
type CliFeatureResult = CodexFeatureCommandResult
type CliResumeResult = CodexResumeOptionsResult
type CliForkResult = CodexForkOptionsResult
type CliArchiveResult = CodexArchiveOptionsResult
type CliDeleteResult = CodexDeleteOptionsResult
type CliLoginResult = CodexLoginActionResult
type CliLogoutResult = CodexLogoutResult
type CliMcpResult = CodexMcpCommandResult
type CliPluginResult = CodexPluginCommandResult
type CliCloudResult = CodexCloudCommandResult
type CliServerResult = CodexServerCommandResult
type CliApplicationResult = CodexApplicationCommandResult
type CliAppServerResult = CodexAppServerCommandResult
type CliUtilityResult = CodexUtilityCommandResult
type CliDebugResult = CodexDebugCommandResult
type CliExecPolicyResult = CodexExecPolicyCommandResult
type CliSandboxResult = CodexSandboxOptionsResult

const parse_cli: CliArgs -> CliPlan = (args: CliArgs) => {
  if let `Cons node = args {
    let [name, remaining] = node
    if name == "completion" {
      let parsed: CliCompletionResult = parse_completion_options remaining
      if let `Ok options = parsed {
        `GenerateCompletion options
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "completion parser returned an unknown result"
      }
    } else if name == "features" {
      let parsed: CliFeatureResult = parse_feature_command remaining
      if let `Ok feature = parsed {
        `ManageFeature feature
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "feature parser returned an unknown result"
      }
    } else if name == "update" {
      if let `Nil () = remaining {
        `UpdateBinary ()
      } else {
        `Invalid "update does not accept arguments"
      }
    } else if name == "login" {
      let parsed: CliLoginResult = parse_login_options remaining
      if let `Ok action = parsed {
        `Authenticate action
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "login parser returned an unknown result"
      }
    } else if name == "logout" {
      let parsed: CliLogoutResult = parse_logout_options remaining
      if let `Ok () = parsed {
        `LogoutAuth ()
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "logout parser returned an unknown result"
      }
    } else if name == "mcp" {
      let parsed: CliMcpResult = parse_mcp_options remaining
      if let `Ok command = parsed {
        `ManageMcp command
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "MCP parser returned an unknown result"
      }
    } else if name == "plugin" {
      let parsed: CliPluginResult = parse_plugin_options remaining
      if let `Ok command = parsed {
        `ManagePlugin command
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "plugin parser returned an unknown result"
      }
    } else if name == "cloud" || name == "cloud-tasks" {
      let parsed: CliCloudResult = parse_cloud_options remaining
      if let `Ok command = parsed {
        `ManageCloud command
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "cloud parser returned an unknown result"
      }
    } else if name == "mcp-server" {
      let parsed: CliServerResult = parse_mcp_server_options remaining
      if let `Ok command = parsed {
        `ManageServer command
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "MCP server parser returned an unknown result"
      }
    } else if name == "exec-server" {
      let parsed: CliServerResult = parse_exec_server_options remaining
      if let `Ok command = parsed {
        `ManageServer command
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "exec server parser returned an unknown result"
      }
    } else if name == "stdio-to-uds" {
      let parsed: CliServerResult = parse_stdio_to_uds_options remaining
      if let `Ok command = parsed {
        `ManageServer command
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "stdio relay parser returned an unknown result"
      }
    } else if name == "app" {
      let parsed: CliApplicationResult = parse_desktop_app_options remaining
      if let `Ok command = parsed {
        `ManageApplication command
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "desktop app parser returned an unknown result"
      }
    } else if name == "remote-control" {
      let parsed: CliApplicationResult = parse_remote_control_options remaining
      if let `Ok command = parsed {
        `ManageApplication command
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "remote-control parser returned an unknown result"
      }
    } else if name == "app-server" {
      let parsed: CliAppServerResult = parse_app_server_options remaining
      if let `Ok command = parsed {
        `ManageAppServer command
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "app-server parser returned an unknown result"
      }
    } else if name == "doctor" {
      let parsed: CliUtilityResult = parse_doctor_options remaining
      if let `Ok command = parsed {
        `ManageUtility command
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "doctor parser returned an unknown result"
      }
    } else if name == "apply" || name == "a" {
      let parsed: CliUtilityResult = parse_apply_options remaining
      if let `Ok command = parsed {
        `ManageUtility command
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "apply parser returned an unknown result"
      }
    } else if name == "responses-api-proxy" {
      let parsed: CliUtilityResult = parse_responses_proxy_options remaining
      if let `Ok command = parsed {
        `ManageUtility command
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "responses-api-proxy parser returned an unknown result"
      }
    } else if name == "debug" {
      let parsed: CliDebugResult = parse_debug_options remaining
      if let `Ok command = parsed {
        `ManageDebug command
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "debug parser returned an unknown result"
      }
    } else if name == "execpolicy" {
      let parsed: CliExecPolicyResult = parse_execpolicy_options remaining
      if let `Ok command = parsed {
        `ManageExecPolicy command
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "execpolicy parser returned an unknown result"
      }
    } else if name == "sandbox" {
      let parsed: CliSandboxResult = parse_sandbox_options remaining
      if let `Ok options = parsed {
        `RunSandbox options
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "sandbox parser returned an unknown result"
      }
    } else if name == "resume" {
      let parsed: CliResumeResult = parse_resume_options remaining
      if let `Ok options = parsed {
        `ResumeSession options
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "resume parser returned an unknown result"
      }
    } else if name == "fork" {
      let parsed: CliForkResult = parse_fork_options remaining
      if let `Ok options = parsed {
        `ForkSession options
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "fork parser returned an unknown result"
      }
    } else if name == "archive" || name == "unarchive" {
      let parsed: CliArchiveResult = parse_archive_options remaining
      if let `Ok options = parsed {
        if name == "archive" { `ArchiveSession options } else { `UnarchiveSession options }
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "archive parser returned an unknown result"
      }
    } else if name == "delete" {
      let parsed: CliDeleteResult = parse_delete_options remaining
      if let `Ok options = parsed {
        `DeleteSession options
      } else if let `Err message = parsed {
        `Invalid message
      } else {
        `Invalid "delete parser returned an unknown result"
      }
    } else {
      `Command (classify_cli_head args)
    }
  } else {
    `Command (classify_cli_head args)
  }
}

return {
  classify_cli_head,
  parse_cli,
}
