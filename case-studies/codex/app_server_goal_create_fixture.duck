const { .plan_thread_goal_set } = import "./app_server_goals.duck" ();
const {} = import "./app_server_types.duck" ();
const {} = import "./app_server_goal_types.duck" ();

type FixtureGoalOption = AppServerThreadGoalOption
type FixtureParams = AppServerThreadGoalSetParams
type FixtureResult = AppServerThreadGoalSetPlanResult

let no_goal: FixtureGoalOption = `None ();
let params: FixtureParams = ["thread-1", `Some "　Ship Codex　", `None (), `Set 1000i64];
let result: FixtureResult = plan_thread_goal_set(no_goal, params);
let score = 0;
if let `GoalSetPlanned planned = result {
  if let `CreateThreadGoal plan = planned {
    let status_valid = if let `GoalActive () = plan.status { true } else { false };
    let budget_valid = if let `Some value = plan.token_budget { value == 1000i64 } else { false };
    if plan.thread_id == "thread-1" && plan.objective == "Ship Codex" && status_valid && budget_valid { score = score + 1 }
  }
}

return { .score = score };
