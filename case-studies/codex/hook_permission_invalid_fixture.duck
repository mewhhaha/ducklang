module () where

const hook_types_module = import "./hook_types.duck"
const hook_output_types_module = import "./hook_output_types.duck"
const hook_output_module = import "./hook_output.duck"
const { parse_permission_output } = hook_output_module()

let parsed = parse_permission_output("{\"hookSpecificOutput\":{\"hookEventName\":\"PermissionRequest\",\"decision\":{\"behavior\":\"allow\",\"updatedInput\":{}}}}")
let score: I32 = 0

if let `PermissionOk output = parsed {
  let [_, decision, invalid] = output

  if let `None () = decision {
    if let `Some message = invalid {
      if message == "PermissionRequest hook returned unsupported updatedInput" {
        score = 1
      }
    }
  }
}

return { .score = score }
