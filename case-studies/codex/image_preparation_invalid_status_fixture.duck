  import "./image_preparation_failure_fixture_common.duck" ();

const verify_image_preparation_invalid_status_fixture: () -> I32 = () => {
  let responses = single_image_processing_fixture_response();
  let results = single_image_processing_fixture_result(9, "");
  let rewrite = apply_image_processing_results(responses, results);
  if let `RejectedImageRewrite failure = rewrite {
    if let `InvalidImageProcessingStatus status_code = failure {
      if status_code == 9 { 1 } else { 0 }
    } else {
      0
    }
  } else {
    0
  }
};

return { .verify_image_preparation_invalid_status_fixture };
