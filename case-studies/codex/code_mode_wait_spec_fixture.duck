module () where

const {} = import "./tool_types.duck" ();
const { .code_mode_wait_tool_name, .code_mode_wait_tool_spec } =
  import "./code_mode_wait_spec.duck" ();

type FixtureSpec = ToolSpec

let score = 0;

let [namespace, local_name] = code_mode_wait_tool_name();
if namespace == "" && local_name == "wait" { score = score + 1 }

let spec: FixtureSpec = code_mode_wait_tool_spec();
let [spec_name, kind, description, parameters, output_schema, strict] = spec;
let [spec_namespace, spec_local_name] = spec_name;
let expected_description =
  "Waits on a yielded `exec` cell and returns new output or completion.\n- Use `wait` only after `exec` returns `Script running with cell ID ...`.\n- `cell_id` identifies the running `exec` cell to resume.\n- `yield_time_ms` controls how long to wait for more output before yielding again. Defaults to 10000 ms.\n- `max_tokens` limits how much new output this wait call returns. Defaults to 10000 tokens.\n- `terminate: true` stops the running cell; false or omitted waits for output.\n- `wait` returns only the new output since the last yield, or the final completion or termination result for that cell.\n- If the cell is still running, `wait` may yield again with the same `cell_id`.\n- If the cell has already finished, `wait` returns the completed result and closes the cell.";
if spec_namespace == "" && spec_local_name == "wait" && description == expected_description && !(
  strict
) {
  if let `FunctionSpec () = kind {
    if let `ToolOutputSchemaMissing () = output_schema { score = score + 10 }
  }
}

let expected_parameters =
  "{\"type\":\"object\",\"properties\":{\"cell_id\":{\"type\":\"string\",\"description\":\"Identifier of the running exec cell.\"},\"max_tokens\":{\"type\":\"number\",\"description\":\"Output token budget for this wait call. Defaults to 10000 tokens.\"},\"terminate\":{\"type\":\"boolean\",\"description\":\"True stops the running exec cell; false or omitted waits for output.\"},\"yield_time_ms\":{\"type\":\"number\",\"description\":\"Wait before yielding more output. Defaults to 10000 ms.\"}},\"required\":[\"cell_id\"],\"additionalProperties\":false}";
if parameters == expected_parameters { score = score + 100 }

return { .score = score };
