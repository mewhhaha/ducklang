module () where

const { parse_json_document } = import "duck:prelude/json" ()
const {} = import "duck:prelude/json/values" ()
const { parse_i64_decimal } = import "duck:prelude/numeric/parse" ()
const { format_i32, text_append } = import "duck:prelude/runtime" ()
const {} = import "./agent_tool_types.duck" ()

type AgentWaitJsonOption = AgentI64Option

const wait_decode_failure: Text -> AgentToolWaitDecodeResult = reason => {
  `AgentWaitDecodeFailed (text_append("failed to parse wait_agent arguments: ", reason))
}

const parse_wait_agent_args: Text -> AgentToolWaitDecodeResult = document => {
  let parsed = parse_json_document document
  if let `Err error = parsed {
    let [position, message] = error
    return wait_decode_failure(text_append(message, text_append(" at byte ", format_i32 position)))
  }
  if let `Ok value_and_position = parsed {
    let [value, _] = value_and_position
    if let `Object object = value {
      let timeout: AgentWaitJsonOption = `None ()
      let seen_timeout = false
      let failure = ""
      let current = object
      let done = false
      loop {
        if failure != "" { break }
        if let `Cons node = current {
          let [member, tail] = node
          let [key, field] = member
          if key != "timeout_ms" {
            failure = text_append("unknown wait_agent field: ", key)
          } else if seen_timeout {
            failure = "timeout_ms must not be repeated"
          } else if let `Number number = field {
            let parsed_timeout = parse_i64_decimal number
            if let `Ok value = parsed_timeout {
              timeout = `Some value
              seen_timeout = true
            } else {
              failure = "timeout_ms must be an integer"
            }
          } else {
            failure = "timeout_ms must be a number"
          }
          current = tail
        } else {
          done = true
        }
        if done { break }
      }
      if failure == "" { `AgentWaitDecoded timeout } else { wait_decode_failure failure }
    } else {
      wait_decode_failure "arguments must be an object"
    }
  } else {
    wait_decode_failure "JSON parsing produced no result"
  }
}

return { parse_wait_agent_args }
