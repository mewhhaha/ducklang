module () where

const {} = import "./agent_spawn_override_types.duck" ();
const { .select_spawn_overrides } = import "./agent_spawn_override.duck" ();
const { .fixture_override_input } = import "./agent_spawn_override_fixture_values.duck" ();

let score = 0;
let result = select_spawn_overrides(
  fixture_override_input(`Some "alpha", `Some "low", `None (), `None ())
);
if let `SpawnOverrideSelected selection = result {
  if selection.model == "alpha" {
    if let `Some effort = selection.reasoning_effort {
      if effort == "low" { score = 1 }
    }
  }
}

return { .score = score };
