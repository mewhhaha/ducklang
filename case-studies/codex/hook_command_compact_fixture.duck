module () where

const hook_types_module = import "./hook_types.duck"
const hook_command_module = import "./hook_command.duck"
const { evaluate_hook_command } = hook_command_module()

type FixtureResult = HookCommandResult

let result: FixtureResult = [`None (), `Some 0, "{\"continue\":false,\"stopReason\":\"pause\"}", ""]
let [status, _, _, _, _, _, _] = evaluate_hook_command(`PreCompact (), result)
let score: I32 = 0

if let `Stopped () = status { score = 1 }

return { .score = score }
