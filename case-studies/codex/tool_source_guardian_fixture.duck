const { .text_append } = import "duck:prelude/functional" ();
const { .tool_source_definitions } = import "./tool_source_plan.duck" ();
const {} = import "./tool_source_types.duck" ();
const {} = import "./tool_types.duck" ();

type FixtureEnvironment = ToolSourceEnvironment
type FixtureFacts = ToolSourceFacts
type FixtureDefinition = SourceDefinition
type FixtureDefinitions = ToolSourceDefinitions

const guardian_facts: FixtureEnvironment -> FixtureFacts = environment => {
  [
    .guardian_reviewer = true,
    .environment = environment,
    .shell = `DisabledShell (),
    .has_mcp_servers = true,
    .deferred_executor = true,
    .request_user_input = true,
    .request_permissions = true,
    .token_budget = true,
    .current_time = true,
    .sleep_tool = true,
    .plugin_install = `ListPluginInstall (),
    .apply_patch = true,
    .test_sync = true,
    .collaboration = `CollaborationV2 (),
    .collaboration_direct_model_only = true,
    .namespace_tools = true,
    .collaboration_namespace = "collaboration",
    .tool_search = true,
    .agent_jobs = true,
    .agent_job_worker = true]
};

let configured: FixtureDefinition = [
  ["fixture", "configured"],
  `Deferred (),
  `Dynamic "configured",
  `FunctionPayload (),
  false,
  false,
];
let configured_runtimes: FixtureDefinitions = `Cons ([configured, `Nil ()]);
let empty_extension_runtimes: FixtureDefinitions = `Nil ();
let empty_dynamic_runtimes: FixtureDefinitions = `Nil ();
let current = tool_source_definitions(
  guardian_facts(`MultipleEnvironments ()),
  configured_runtimes,
  empty_extension_runtimes,
  empty_dynamic_runtimes,
);
let score = 0;
let trace = "";
let handler_count = 0;
let done = false;

loop {
  if let `Cons node = current {
    let [definition, tail] = node;
    let [[_, local_name], _, tool_handler, _, _, _] = definition;
    trace = text_append [local_name, text_append ["|", trace]]
    if local_name == "exec_command" {
      if let `UnifiedExec () = tool_handler { handler_count = handler_count + 1 }
    } else if local_name == "write_stdin" {
      if let `WriteStdin () = tool_handler { handler_count = handler_count + 1 }
    } else if local_name == "view_image" {
      if let `ViewImage () = tool_handler { handler_count = handler_count + 1 }
    }
    current = tail
  } else {
    done = true
  }

  if done { break; }
}

if trace == "view_image|write_stdin|exec_command|" { score = score + 1 }
if handler_count == 3 { score = score + 10 }
let empty_configured_runtimes: FixtureDefinitions = `Nil ();
empty_extension_runtimes = `Nil ()
empty_dynamic_runtimes = `Nil ()
if let `Nil () = tool_source_definitions(
  guardian_facts(`NoEnvironment ()),
  empty_configured_runtimes,
  empty_extension_runtimes,
  empty_dynamic_runtimes,
) {
  score = score + 100
}

return { .score = score };
