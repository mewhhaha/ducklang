const { parse_json } = import "duck:prelude/json" ()
const { text_length } = import "duck:prelude/runtime" ()

let document = "{\"type\":\"function_call\",\"arguments\":\"{\\\"path\\\":\\\"README.md\\\"}\",\"flags\":[true,false,null],\"number\":-12.5e+2}"
let parsed = parse_json(document, 0)

if let `Ok value_and_index = parsed {
  let [value, index] = value_and_index
  let score = if index == text_length(document) { 10000 } else { 0 }

  if let `Object members = value {
    let current = members
    let done = false

    loop {
      if let `Cons node = current {
        let [member, tail] = node
        let [key, member_value] = member

        if key == "type" {
          if let `String text = member_value {
            if text == "function_call" {
              score = score + 1
            }
          }
        } else if key == "arguments" {
          if let `String text = member_value {
            if text == "{\"path\":\"README.md\"}" {
              score = score + 10
            }
          }
        } else if key == "flags" {
          if let `Array values = member_value {
            let flags = values
            let flag_score = 0
            let flag_index = 0
            let flags_done = false

            loop {
              if let `Cons flag_node = flags {
                let [flag, tail_flags] = flag_node

                if flag_index == 0 {
                  if let `Bool true = flag {
                    flag_score = flag_score + 1
                  }
                } else if flag_index == 1 {
                  if let `Bool false = flag {
                    flag_score = flag_score + 2
                  }
                } else if flag_index == 2 {
                  if let `Null () = flag {
                    flag_score = flag_score + 3
                  }
                }

                flags = tail_flags
                flag_index = flag_index + 1
              } else {
                flags_done = true
              }

              if flags_done {
                break
              }
            }

            if flag_score == 6 && flag_index == 3 {
              score = score + 100
            }
          }
        } else if key == "number" {
          if let `Number number = member_value {
            if number == "-12.5e+2" {
              score = score + 1000
            }
          }
        }

        current = tail
      } else {
        done = true
      }

      if done {
        break
      }
    }

    score
  } else {
    -1
  }
} else {
  -2
}
