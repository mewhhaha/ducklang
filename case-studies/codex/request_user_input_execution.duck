module () where

const {} = import "./request_user_input_types.duck" ();
const { .encode_request_user_input_response } = import "./request_user_input_output.duck" ();

type UserInputHostResponse = RequestUserInputHostResponse
type UserInputExecutionResult = RequestUserInputExecutionResult

const finish_request_user_input: UserInputHostResponse -> UserInputExecutionResult = response => {
  if let `Answered answer = response {
    `Completed (encode_request_user_input_response answer)
  } else {
    `Rejected "request_user_input was cancelled before receiving a response"
  }
};

return { .finish_request_user_input };
