module () where

const {} = import "duck:prelude/types" ()
const {} = import "./tool_types.duck" ()
const { request_user_input_tool_description } = import "./request_user_input_description.duck" ()

type UserInputToolDefinition = ToolDefinition
type UserInputToolDefinitionNode = ToolDefinitionNode
type UserInputToolDefinitions = ToolDefinitions
type UserInputToolName = ToolName
type UserInputToolSpec = ToolSpec
type UserInputToolSpecNode = ToolSpecNode
type UserInputToolSpecs = ToolSpecs

const request_user_input_tool_name: () -> UserInputToolName = () => ["", "request_user_input"]

const request_user_input_tool_definitions: Bool -> UserInputToolDefinitions = enabled => {
  if enabled {
    let definition: UserInputToolDefinition = [request_user_input_tool_name(), `DirectModelOnly (), `RequestUserInput (), `FunctionPayload (), false, false]
    let empty: UserInputToolDefinitions = `Nil ()
    `Cons ([definition, empty] as UserInputToolDefinitionNode)
  } else {
    `Nil ()
  }
}

const request_user_input_tool_specs: [Bool, Bool] -> UserInputToolSpecs = (enabled: Bool, default_mode_enabled: Bool) => {
  if enabled {
    let parameters = "{\"type\":\"object\",\"properties\":{\"autoResolutionMs\":{\"type\":\"number\",\"description\":\"Optional auto-resolution window in milliseconds, from 60000 to 240000. Include this only when the question is useful but non-blocking and continuing with best judgment is acceptable if the user does not answer; omit it when explicit user input is required before continuing. Use 60000 for lightly helpful context and up to 240000 when the answer would materially unblock better work.\"},\"questions\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"header\":{\"type\":\"string\",\"description\":\"Short header label shown in the UI (12 or fewer chars).\"},\"id\":{\"type\":\"string\",\"description\":\"Stable identifier for mapping answers (snake_case).\"},\"options\":{\"type\":\"array\",\"items\":{\"type\":\"object\",\"properties\":{\"description\":{\"type\":\"string\",\"description\":\"One short sentence explaining impact/tradeoff if selected.\"},\"label\":{\"type\":\"string\",\"description\":\"User-facing label (1-5 words).\"}},\"required\":[\"label\",\"description\"],\"additionalProperties\":false},\"description\":\"Provide 2-3 mutually exclusive choices. Put the recommended option first and suffix its label with \\\"(Recommended)\\\". Do not include an \\\"Other\\\" option in this list; the client will add a free-form \\\"Other\\\" option automatically.\"},\"question\":{\"type\":\"string\",\"description\":\"Single-sentence prompt shown to the user.\"}},\"required\":[\"id\",\"header\",\"question\",\"options\"],\"additionalProperties\":false},\"description\":\"Questions to show the user. Prefer 1 and do not exceed 3\"}},\"required\":[\"questions\"],\"additionalProperties\":false}"
    let spec: UserInputToolSpec = [request_user_input_tool_name(), `FunctionSpec (), request_user_input_tool_description default_mode_enabled, parameters, `ToolOutputSchemaMissing (), false]
    let empty: UserInputToolSpecs = `Nil ()
    `Cons ([spec, empty] as UserInputToolSpecNode)
  } else {
    `Nil ()
  }
}

return {
  request_user_input_tool_name,
  request_user_input_tool_definitions,
  request_user_input_tool_specs,
}
