module () where

const {} = import "./tool_types.duck" ();
const { .test_sync_tool_definitions } = import "./test_sync_registration.duck" ();

type FixtureDefinitions = ToolDefinitions

let score = 0;
let disabled: FixtureDefinitions = test_sync_tool_definitions false;
if let `Nil () = disabled { score = score + 1 }

let definitions: FixtureDefinitions = test_sync_tool_definitions true;
if let `Cons node = definitions {
  let [definition, tail] = node;
  let [name, exposure, tool_handler, payload, parallel, waits] = definition;
  let [namespace, local_name] = name;
  if namespace == "" && local_name == "test_sync_tool" && parallel && !(waits) {
    if let `Direct () = exposure {
      if let `TestSync () = tool_handler {
        if let `FunctionPayload () = payload {
          if let `Nil () = tail { score = score + 10 }
        }
      }
    }
  }
}

return { .score = score };
