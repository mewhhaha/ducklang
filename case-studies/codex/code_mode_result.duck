module () where

const { .text_append, .text_trim_whitespace } = import "duck:prelude/runtime" ();
const {} = import "./code_mode_nested_tool_types.duck" ();

type ResultContentItems = FunctionOutputContentItems
type ResultBody = CodeModeResultBody
type ResultInput = CodeModeResultInput
type ResultJson = Json
type ResultTextOption = Option Text

const code_mode_content_result: ResultContentItems -> Text = content_items => {
  let current = content_items;
  let output = "";
  let done = false;

  loop {
    if let `Cons node = current {
      let [content_item, tail] = node;
      let value: ResultTextOption = match content_item {
        | `InputText text => `Some text
        | `InputImage image => {
          let [image_url, _] = image;
          `Some image_url
        }
        | `InputAudio audio_url => `Some audio_url
        | `EncryptedContent _ => `None ()
      };

      if let `Some text = value {
        if text_trim_whitespace text != "" {
          if output != "" {
            output = text_append [output, "\n"]
          }
          output = text_append [output, text]
        }
      }

      current = tail
    } else {
      done = true
    }

    if done { break; }
  }

  output
};

const code_mode_result: ResultInput -> ResultJson = input => {
  match input {
    | `ResultMessage content_items => `String (code_mode_content_result content_items)
    | `ResultFunctionCall body | `ResultCustomCall body => {
      match body {
        | `ResultTextBody text => `String text
        | `ResultContentBody content_items => `String (code_mode_content_result content_items)
      }
    }
    | `ResultToolSearch tools => `Array tools
    | `ResultMcpCall result => result
    | `ResultJsonToolOutput value => value
  }
};

return {
  .code_mode_content_result,
  .code_mode_result,
};
