module () where

const {} = import "./hosted_tool_types.duck" ();

type HostedAvailabilityFacts = HostedToolAvailabilityFacts

const hosted_web_search_available: HostedAvailabilityFacts -> Bool = facts => {
  if facts.use_responses_lite {
    return false;
  }

  let standalone_enabled = facts.namespace_tools && facts.standalone_web_search;
  if standalone_enabled && facts.has_web_run_executor {
    return false;
  }
  if !(facts.provider_web_search) {
    return false;
  }
  if let `Disabled () = facts.web_search_mode {
    return false;
  }

  true
};

return { .hosted_web_search_available };
