module () where

const hook_output_types_module = import "./hook_output_types.duck";
const hook_output_module = import "./hook_output.duck";
const { .parse_post_tool_output } = hook_output_module();

type FixturePostToolParse = HookPostToolParse

let parsed: FixturePostToolParse =
  parse_post_tool_output "{\"continue\":false,\"stopReason\":\"stop\",\"decision\":\"block\",\"reason\":\"feedback\",\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"context\"}}";
let score = 0;

if let `PostToolOk output = parsed {
  let [universal, should_block, reason, invalid_block, additional_context, invalid] = output;
  let [continue_processing, stop_reason, _, _] = universal;

  if continue_processing {
    ()
  } else if let `Some value = stop_reason {
    if value == "stop" { score = score * 10 + 1 }
  }

  if should_block { score = score * 10 + 1 }
  if let `Some value = reason { if value == "feedback" { score = score * 10 + 1 } }
  if let `None () = invalid_block { score = score * 10 + 1 }
  if let `Some value = additional_context { if value == "context" { score = score * 10 + 1 } }
  if let `None () = invalid { score = score * 10 + 1 }
}

return { .score = score };
