module () where

const hook_types_module = import "./hook_types.duck";
const hook_output_types_module = import "./hook_output_types.duck";
const hook_output_module = import "./hook_output.duck";
const { .parse_pre_tool_output } = hook_output_module();

let parsed =
  parse_pre_tool_output "{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"allow\",\"updatedInput\":{\"path\":\"x\"},\"additionalContext\":\"read policy\"}}";
let score: I32 = 0;

if let `PreToolOk output = parsed {
  let [_, block_reason, additional_context, updated_input, invalid] = output;

  if let `None () = block_reason {
    score = score + 1
  }

  if let `Some value = additional_context {
    if value == "read policy" { score = score + 10 }
  }

  if let `UpdatedInput value = updated_input {
    if value == "{\"path\":\"x\"}" { score = score + 100 }
  }

  if let `None () = invalid {
    score = score + 1000
  }
}

return { .score = score };
