module () where

const agent_types_module = import "./agent_types.duck";
const agent_wait_module = import "./agent_wait.duck";
const { .select_wait_outcome, .status_entries_empty, .status_entries_length, .status_entries_prepend } =
  agent_wait_module();

type FixtureStatus = AgentStatus

let running: FixtureStatus = `Running ();
let initial = status_entries_prepend(["agent", running], status_entries_empty());
let [selected, timed_out] = select_wait_outcome(initial, status_entries_empty());
let score: I32 = 0;

if timed_out && status_entries_length selected == 0 {
  score = 1
}

return { .score = score };
