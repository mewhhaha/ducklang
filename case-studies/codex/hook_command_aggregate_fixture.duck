module () where

const { .list } = import "duck:prelude/functional" ();
const hook_types_module = import "./hook_types.duck";
const hook_command_module = import "./hook_command.duck";
const {
  .action_is_stop,
  .aggregate_hook_command,
  .block_action,
  .empty_hook_command_aggregate,
  .stop_action,
} = hook_command_module();

type FixtureEvaluation = HookCommandEvaluation
type FixtureEntry = HookOutputEntry
type FixtureEntries = HookOutputEntries
type FixtureTexts = HookTexts

const fixture_entries = comptime list FixtureEntry;
const fixture_texts = comptime list Text;

let score: I32 = 0;
let first: FixtureEvaluation = [
  `Blocked (),
  fixture_entries.empty(),
  block_action "first",
  fixture_texts.singleton("one"),
  fixture_texts.empty(),
  `UpdatedInput "one",
  `Some (`Allow ()),
];
let second: FixtureEvaluation = [
  `Stopped (),
  fixture_entries.empty(),
  stop_action(`Some "done"),
  fixture_texts.singleton("two"),
  fixture_texts.empty(),
  `UpdatedInput "two",
  `Some (`Deny "denied"),
];
let aggregate = empty_hook_command_aggregate();
aggregate = aggregate_hook_command(aggregate, first)
aggregate = aggregate_hook_command(aggregate, second)
let [aggregate_action, aggregate_contexts, _, aggregate_updated, aggregate_permission] = aggregate;

let [_, reason] = aggregate_action;
if action_is_stop aggregate_action {
  if let `Some stop_reason = reason {
    if stop_reason == "done" && fixture_texts.length(aggregate_contexts) == 2 {
      if let `UpdatedInput updated = aggregate_updated {
        if updated == "two" {
          if let `Some decision = aggregate_permission {
            if let `Deny denial = decision {
              if denial == "denied" { score = score + 1 }
            }
          }
        }
      }
    }
  }
}

return { .score = score };
