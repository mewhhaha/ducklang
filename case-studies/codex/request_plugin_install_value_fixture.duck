module () where

const { json_object, json_object_empty, json_object_prepend, json_string } = import "duck:prelude/json/values" ()
const {} = import "./plugin_install_types.duck" ()
const { decode_list_plugin_install_value, decode_recommended_plugin_install_value } = import "./request_plugin_install_value.duck" ()

let score = 0
let list_fields = json_object_prepend("tool_type", json_string("plugin"), json_object_prepend("action_type", json_string("enable"), json_object_prepend("tool_id", json_string("sample@remote"), json_object_prepend("suggest_reason", json_string("Use sample"), json_object_empty()))))
if let `Parsed args = decode_list_plugin_install_value(list_fields) {
  if args.tool_id == "sample@remote" {
    if let `Plugin () = args.tool_type {
      if let `Enable () = args.action_type { score = score + 1 }
    }
  }
}

let recommended_fields = json_object_prepend("tool_id", json_string("sample@remote"), json_object_prepend("suggest_reason", json_string("Use sample"), json_object_empty()))
if let `Parsed args = decode_recommended_plugin_install_value(recommended_fields) {
  if args.plugin_id == "sample@remote" { score = score + 10 }
}

let unknown_fields = json_object_prepend("plugin_id", json_string("sample"), json_object_prepend("suggest_reason", json_string("reason"), json_object_prepend("extra", json_string("no"), json_object_empty())))
if let `ParseFailed message = decode_recommended_plugin_install_value(unknown_fields) {
  if message == "failed to parse function arguments: request_plugin_install arguments contain an unknown field" { score = score + 100 }
}

let duplicate_alias_fields = json_object_prepend("plugin_id", json_string("sample"), json_object_prepend("tool_id", json_string("sample"), json_object_prepend("suggest_reason", json_string("reason"), json_object_empty())))
if let `ParseFailed message = decode_recommended_plugin_install_value(duplicate_alias_fields) {
  if message == "failed to parse function arguments: request_plugin_install requires exactly one plugin_id and suggest_reason" { score = score + 1000 }
}

return { .score = score }
