module () where

const {} = import "./plugin_install_types.duck" ();
const { .finish_request_plugin_install } = import "./request_plugin_install_execution.duck" ();

type FixtureCandidate = PluginInstallCandidate
type FixtureHostRequest = RequestPluginInstallHostRequest
type FixtureHostResponse = RequestPluginInstallHostResponse
type FixtureTextOption = InstallTextOption
type FixtureTexts = InstallTexts

let none: FixtureTextOption = `InstallTextMissing ();
let empty_texts: FixtureTexts = `Nil ();
let candidate: FixtureCandidate = [
  .id = "calendar",
  .name = "Calendar",
  .description = none,
  .tool_type = `Connector (),
  .has_skills = false,
  .mcp_server_names = empty_texts,
  .app_connector_ids = empty_texts,
  .install_url = `InstallTextPresent "https://example.com/calendar",
  .remote_plugin_id = none,
];
let request: FixtureHostRequest = [
  .suggestion_id = "request_plugin_install_call-1",
  .suggest_reason = "Plan events",
  .candidate = candidate,
];
let accepted: FixtureHostResponse = [
  .sent = true,
  .action = `Accept (),
  .persist_always = false,
  .verified = true,
];
let completed = finish_request_plugin_install(request, accepted);
let score = 0;

if completed.output == "{\"completed\":true,\"user_confirmed\":true,\"tool_type\":\"connector\",\"action_type\":\"install\",\"tool_id\":\"calendar\",\"tool_name\":\"Calendar\",\"suggest_reason\":\"Plan events\"}" && completed.merge_connector && !(
  completed.persist_disabled
) && completed.record_telemetry && completed.response_action == "accept" {
  score = 1
}

return { .score = score };
