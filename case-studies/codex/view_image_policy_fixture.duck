module () where

const {} = import "./view_image_types.duck" ()
const { prepare_view_image } = import "./view_image_policy.duck" ()

type FixtureArgs = ViewImageArgs
type FixtureDetailOption = ViewImageDetailOption
type FixtureEnvironment = ViewImageEnvironment
type FixtureEnvironmentNode = ViewImageEnvironmentNode
type FixtureEnvironments = ViewImageEnvironments
type FixtureTextOption = ViewImageTextOption

let score = 0

let default_environment: FixtureEnvironment = [.environment_id = "local", .cwd = "/workspace", .is_primary = true]
let default_environments: FixtureEnvironments = `Cons ([default_environment, `Nil ()] as FixtureEnvironmentNode)
let default_args: FixtureArgs = [.path = "images/a.png", .environment_id = `ImageEnvironmentMissing (), .detail = `ImageDetailMissing ()]
let default_detail = prepare_view_image("call-1", default_args, default_environments, true)
if let `ReadImage prepared = default_detail {
  if prepared.call_id == "call-1" && prepared.environment_id == "local" && prepared.path == "/workspace/images/a.png" {
    if let `High () = prepared.detail { score = score + 1 }
  }
}

let remote_id: FixtureTextOption = `ImageEnvironmentPresent "remote"
let original_detail: FixtureDetailOption = `ImageDetailPresent (`Original ())
let original_environment: FixtureEnvironment = [.environment_id = "remote", .cwd = "/remote", .is_primary = false]
let original_environments: FixtureEnvironments = `Cons ([original_environment, `Nil ()] as FixtureEnvironmentNode)
let original_args: FixtureArgs = [.path = "/image.png", .environment_id = remote_id, .detail = original_detail]
let original = prepare_view_image("call-2", original_args, original_environments, true)
if let `ReadImage prepared = original {
  if prepared.environment_id == "remote" && prepared.path == "/image.png" {
    if let `Original () = prepared.detail { score = score + 10 }
  }
}

let downgraded_environment: FixtureEnvironment = [.environment_id = "remote", .cwd = "/remote", .is_primary = false]
let downgraded_environments: FixtureEnvironments = `Cons ([downgraded_environment, `Nil ()] as FixtureEnvironmentNode)
let downgraded_args: FixtureArgs = [.path = "/image.png", .environment_id = `ImageEnvironmentPresent "remote", .detail = `ImageDetailPresent (`Original ())]
let downgraded = prepare_view_image("call-3", downgraded_args, downgraded_environments, false)
if let `ReadImage prepared = downgraded {
  if let `High () = prepared.detail { score = score + 100 }
}

let missing_id: FixtureTextOption = `ImageEnvironmentPresent "missing"
let missing_args: FixtureArgs = [.path = "a.png", .environment_id = missing_id, .detail = `ImageDetailMissing ()]
let missing_environments: FixtureEnvironments = `Nil ()
let unknown_environment = prepare_view_image("call-4", missing_args, missing_environments, true)
if let `RejectRequest message = unknown_environment {
  if message == "unknown turn environment id `missing`" { score = score + 1000 }
}

return { .score = score }
