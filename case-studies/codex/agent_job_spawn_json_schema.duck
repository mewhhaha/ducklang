module () where

const { .encode_json, .json_object_get, .parse_json_document } = import "duck:prelude/json" ();
const {} = import "./agent_job_spawn_types.duck" ();

type AgentJobSpawnSchemaArgs = AgentJobSpawnDecodedArgs
type AgentJobSpawnSchemaResult = AgentJobSpawnDecodeResult

let decode_agent_job_spawn_schema: [Text, AgentJobSpawnSchemaArgs] -> AgentJobSpawnSchemaResult = (
  document: Text,
  base: AgentJobSpawnSchemaArgs,
) => {
  let parsed = parse_json_document document;
  if let `Ok value_and_position = parsed {
    let [value, _] = value_and_position;
    if let `Object object = value {
      let lookup = json_object_get("output_schema", object);
      if let `Missing () = lookup {
        let args: AgentJobSpawnSchemaArgs = [
          .csv_path = base.csv_path,
          .instruction = base.instruction,
          .id_column = base.id_column,
          .output_path = base.output_path,
          .output_schema_json = `None (),
          .max_concurrency = base.max_concurrency,
          .max_workers = base.max_workers,
          .max_runtime_seconds = base.max_runtime_seconds,
        ];
        `SpawnDecoded args
      } else if let `Found field = lookup {
        if let `Null () = field {
          let args: AgentJobSpawnSchemaArgs = [
            .csv_path = base.csv_path,
            .instruction = base.instruction,
            .id_column = base.id_column,
            .output_path = base.output_path,
            .output_schema_json = `None (),
            .max_concurrency = base.max_concurrency,
            .max_workers = base.max_workers,
            .max_runtime_seconds = base.max_runtime_seconds,
          ];
          `SpawnDecoded args
        } else if let `Object _ = field {
          let args: AgentJobSpawnSchemaArgs = [
            .csv_path = base.csv_path,
            .instruction = base.instruction,
            .id_column = base.id_column,
            .output_path = base.output_path,
            .output_schema_json = `Some (encode_json field),
            .max_concurrency = base.max_concurrency,
            .max_workers = base.max_workers,
            .max_runtime_seconds = base.max_runtime_seconds,
          ];
          `SpawnDecoded args
        } else {
          `SpawnDecodeFailed "output_schema must be a JSON object"
        }
      } else {
        `SpawnDecodeFailed "output_schema decoder returned no result"
      }
    } else {
      `SpawnDecodeFailed "failed to parse function arguments: expected an object"
    }
  } else {
    `SpawnDecodeFailed "failed to parse function arguments: invalid JSON"
  }
};

return { .decode_agent_job_spawn_schema };
