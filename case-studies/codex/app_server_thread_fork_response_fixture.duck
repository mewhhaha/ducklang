module () where

const { json_object, json_object_empty, json_object_get, json_string } = import "duck:prelude/json" ()
const { materialize_thread_fork_response } = import "./app_server_thread_responses.duck" ()
const {} = import "./app_server_thread_response_types.duck" ()

type FixtureMetadata = AppServerThreadResponseMetadata
type FixtureTexts = AppServerTexts

let empty_texts: FixtureTexts = `Nil ()
let metadata: FixtureMetadata = [json_object(json_object_empty()), "gpt-5.4", "openai", `None (), "/repo", empty_texts, empty_texts, json_string("never"), json_string("user"), json_string("read-only"), `None (), `None (), `StableThreadResponse ()]
let score = if let `Object fields = materialize_thread_fork_response(metadata) {
  if let `Found value = json_object_get("model", fields) {
    if let `String model = value { if model == "gpt-5.4" { 1 } else { 0 } } else { 0 }
  } else { 0 }
} else { 0 }

return { .score = score }
