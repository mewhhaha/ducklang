module () where

const { .list } = import "duck:prelude/functional" ();
const instruction_types_module = import "./instruction_types.duck";
const instruction_module = import "./instruction_discovery.duck";
const { .discover_instructions } = instruction_module();

type FixtureSnapshotEntry = InstructionSnapshotEntry
type FixtureDocumentOption = InstructionDocumentOption
type FixtureDiscoveryConfig = InstructionDiscoveryConfig

const snapshot_entries = comptime list FixtureSnapshotEntry;
const instruction_texts = comptime list Text;

let snapshot = snapshot_entries.empty();
snapshot = snapshot_entries.prepend(`File (["/repo/crate/src/PROJECT.md", "abcdef"]), snapshot)
snapshot = snapshot_entries.prepend(`File (["/repo/crate/AGENTS.md", "ignored"]), snapshot)
snapshot = snapshot_entries.prepend(`File (["/repo/crate/AGENTS.override.md", "crate"]), snapshot)
snapshot = snapshot_entries.prepend(`File (["/repo/AGENTS.md", "root"]), snapshot)
snapshot = snapshot_entries.prepend(`Directory "/repo/.git", snapshot)

let fallback_names = instruction_texts.singleton "PROJECT.md";
let root_markers = instruction_texts.singleton ".git";
let user: FixtureDocumentOption = `Some (["/home/me/.codex/AGENTS.md", "global"]);
let config: FixtureDiscoveryConfig = ["/repo/crate/src", 12, fallback_names, root_markers, user];
let loaded = discover_instructions(snapshot, config);
let [text, sources] = loaded;
let score: I32 = instruction_texts.length sources;

if let `Some contents = text {
  if contents == "global\n\n--- project-doc ---\n\nroot\n\ncrate\n\nabc" {
    score = score + 10
  }
}

if instruction_texts.nth_or("", 0, sources) == "/home/me/.codex/AGENTS.md" {
  score = score + 100
}

if instruction_texts.nth_or("", 2, sources) == "/repo/crate/AGENTS.override.md" {
  score = score + 1000
}

let local_config: FixtureDiscoveryConfig = [
  "/repo/crate/src",
  32,
  fallback_names,
  instruction_texts.empty(),
  `None (),
];
let local_loaded = discover_instructions(snapshot, local_config);
let [local_text, local_sources] = local_loaded;

if let `Some contents = local_text {
  if contents == "abcdef" && instruction_texts.length(local_sources) == 1 {
    score = score + 10000
  }
}

return { .score = score };
