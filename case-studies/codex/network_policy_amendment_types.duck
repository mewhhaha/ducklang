module () where

const { .struct } = import "duck:prelude/types" ();
const {} = import "./network_policy_types.duck" ();

type NetworkPolicyRuleAction =
  | `AllowRule Unit
  | `DenyRule Unit

type NetworkPolicyAmendment = struct {
  .host = Text,
  .action = NetworkPolicyRuleAction,
}

type NetworkExecPolicyProtocol =
  | `ExecHttp Unit
  | `ExecHttps Unit
  | `ExecSocks5Tcp Unit
  | `ExecSocks5Udp Unit

type NetworkExecPolicyDecision =
  | `ExecAllow Unit
  | `ExecForbidden Unit

type NetworkExecPolicyAmendment = struct {
  .protocol = NetworkExecPolicyProtocol,
  .decision = NetworkExecPolicyDecision,
  .justification = Text,
}

return {};
