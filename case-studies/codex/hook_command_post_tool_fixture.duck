module () where

const { list } = import "duck:prelude/functional" ()
const hook_types_module = import "./hook_types.duck"
const hook_command_module = import "./hook_command.duck"
const { evaluate_hook_command } = hook_command_module()

type FixtureResult = HookCommandResult
type FixtureTexts = HookTexts

const fixture_texts = comptime list(Text)

let result: FixtureResult = [`None (), `Some 0, "{\"continue\":false,\"stopReason\":\"halt\",\"reason\":\"model feedback\",\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"context\"}}", ""]
let [status, _, _, contexts, feedback, _, _] = evaluate_hook_command(`PostToolUse (), result)
let score: I32 = 0

if let `Stopped () = status {
  if fixture_texts.nth_or("", 0, contexts) == "context" && fixture_texts.nth_or("", 0, feedback) == "model feedback" {
    score = 1
  }
}

return { .score = score }
