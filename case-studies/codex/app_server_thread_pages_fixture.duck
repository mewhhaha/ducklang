module () where

const {
  .encode_json,
  .json_array_empty,
  .json_object,
  .json_object_empty,
  .json_object_prepend,
  .json_string,
} = import "duck:prelude/json" ();
const { .plan_thread_items_list, .plan_thread_turns_list } =
  import "./app_server_thread_pages.duck" ();
const { .materialize_thread_items_page, .materialize_thread_turns_page } =
  import "./app_server_thread_page_responses.duck" ();
const {} = import "./app_server_turn_types.duck" ();
const {} = import "./app_server_types.duck" ();

type FixtureTurnsListParams = AppServerThreadTurnsListParams
type FixtureTurnsListResult = AppServerThreadTurnsListPlanResult
type FixtureTurn = AppServerTurn
type FixtureTurns = AppServerTurns
type FixtureTurnsPage = AppServerThreadTurnsPage
type FixtureItemEntry = AppServerThreadItemEntry
type FixtureItemEntries = AppServerThreadItemEntries
type FixtureItemsPage = AppServerThreadItemsPage
type FixtureItemsListParams = AppServerThreadItemsListParams
type FixtureItemsListPlanResult = AppServerThreadItemsListPlanResult

let score = 0;
let full_params: FixtureTurnsListParams = ["thread-1", `None (), 25, `Descending (), `Full ()];
let paginated_full: FixtureTurnsListResult = plan_thread_turns_list(
  full_params,
  `PaginatedHistory (),
);
if let `Err reason = paginated_full {
  if reason == "thread/turns/list itemsView full is not supported for paginated threads; use thread/items/list" { score = score + 1 }
}

let legacy_full: FixtureTurnsListResult = plan_thread_turns_list(full_params, `LegacyHistory ());
if let `Ok plan = legacy_full {
  let [_, route] = plan;
  if let `LegacyTurnsReplay () = route { score = score + 10 }
}

let summary_params: FixtureTurnsListParams = ["thread-1", `None (), 25, `Descending (), `Summary ()];
let paginated_summary: FixtureTurnsListResult = plan_thread_turns_list(
  summary_params,
  `PaginatedHistory (),
);
if let `Ok plan = paginated_summary {
  let [_, route] = plan;
  if let `PaginatedTurnsStore () = route { score = score + 100 }
}

let turn: FixtureTurn = [
  "turn-1",
  json_array_empty(),
  `Summary (),
  `Completed (),
  `None (),
  `Some 10i64,
  `Some 20i64,
  `Some 10i64,
];
let turns: FixtureTurns = `Cons ([turn, `Nil ()]);
let turns_page: FixtureTurnsPage = [turns, `Some "next-turn", `None ()];
let turns_json = encode_json(materialize_thread_turns_page turns_page);
if turns_json == "{\"data\":[{\"id\":\"turn-1\",\"items\":[],\"itemsView\":\"summary\",\"status\":\"completed\",\"error\":null,\"startedAt\":10,\"completedAt\":20,\"durationMs\":10}],\"nextCursor\":\"next-turn\",\"backwardsCursor\":null}" { score = score + 1000 }

let item_fields = json_object_prepend("type", json_string "userMessage", json_object_empty());
let entry: FixtureItemEntry = ["turn-1", json_object item_fields];
let entries: FixtureItemEntries = `Cons ([entry, `Nil ()]);
let items_page: FixtureItemsPage = [entries, `None (), `Some "previous-item"];
let items_json = encode_json(materialize_thread_items_page items_page);
if items_json == "{\"data\":[{\"turnId\":\"turn-1\",\"item\":{\"type\":\"userMessage\"}}],\"nextCursor\":null,\"backwardsCursor\":\"previous-item\"}" { score = score + 10000 }

let items_params: FixtureItemsListParams = ["thread-1", `None (), `None (), 25, `Ascending ()];
let unsupported_items: FixtureItemsListPlanResult = plan_thread_items_list(
  items_params,
  `PaginatedListsUnsupported (),
);
if let `Err reason = unsupported_items {
  if reason == "thread/items/list is not supported yet" { score = score + 100000 }
}
let supported_items: FixtureItemsListPlanResult = plan_thread_items_list(
  items_params,
  `PaginatedListsSupported (),
);
if let `Ok _ = supported_items { score = score + 1000000 }

return { .score = score };
