module () where

const {} = import "duck:prelude/types" ();

type OutputImageDetail =
  | `Auto Unit
  | `Low Unit
  | `High Unit
  | `Original Unit

type OutputImageDetailOption =
  | `None Unit
  | `Some OutputImageDetail
type OutputImage = [Text, OutputImageDetailOption]
type HistoryImage = OutputImage

type HistoryContent =
  | `InputText Text
  | `InputImage HistoryImage
  | `InputAudio Text
  | `OutputText Text
  | `Encrypted Text

type HistoryContents = List HistoryContent
type HistoryMessage = [Text, Bool, HistoryContents]
type HistoryCall = [Text, Text, Text, Text]
type HistoryOutput = [Text, Text, HistoryContents]
type HistoryPairedCall = [Text, Text]
type HistoryToolSearchOutput = [Text, Text]

type HistoryItem =
  | `Message HistoryMessage
  | `AgentMessage HistoryContents
  | `Reasoning Text
  | `FunctionCall HistoryCall
  | `FunctionOutput HistoryOutput
  | `CustomCall HistoryCall
  | `CustomOutput HistoryOutput
  | `LocalShellCall HistoryPairedCall
  | `ToolSearchCall HistoryPairedCall
  | `ToolSearchOutput HistoryToolSearchOutput
  | `Compaction Text
  | `Other Unit

type HistoryItems = List HistoryItem
type HistoryItemOption = Option HistoryItem
type HistoryTextOption = Option Text
type InputModalities = [Bool, Bool]

return {};
