module () where

const {} = import "./compact_model_fallback_types.duck" ()
const { compaction_implementation_tag, compaction_reason_tag } = import "./compaction_tags.duck" ()

type ModelFallbackError = CompactionModelError
type ModelFallbackTextOption = CompactionFallbackTextOption
type ModelFallbackTelemetry = CompactionFallbackTelemetry
type ModelFallbackReason = CompactionReason
type ModelFallbackImplementation = CompactionImplementation

const should_retry_with_current_model: ModelFallbackError -> Bool = error => {
  if let `InvalidRequest _ = error {
    true
  } else if let `UnexpectedStatus _ = error {
    true
  } else if let `ContextWindowExceeded () = error {
    true
  } else if let `UsageLimitReached _ = error {
    true
  } else if let `ServerOverloaded () = error {
    true
  } else if let `InternalServerError () = error {
    true
  } else if let `RetryLimit _ = error {
    true
  } else {
    false
  }
}

const model_fallback_telemetry: [Text, Text, ModelFallbackReason, ModelFallbackImplementation, ModelFallbackTextOption] -> ModelFallbackTelemetry = (previous_model, current_model, reason, implementation, fallback_error) => {
  let outcome = if let `None () = fallback_error { "succeeded" } else { "failed" }

  [.metric = "codex.compaction.model_fallback", .increment = 1, .previous_model = previous_model, .current_model = current_model, .reason = compaction_reason_tag(reason), .implementation = compaction_implementation_tag(implementation), .outcome = outcome, .fallback_error = fallback_error, .message = "previous-model compaction failed; retried with current model"]
}

return {
  should_retry_with_current_model,
  model_fallback_telemetry,
}
