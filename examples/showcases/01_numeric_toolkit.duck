const { .pipe } = import "duck:prelude/functional" ();

const double: I32 -> I32 = value => value * 2;
const increment: I32 -> I32 = value => value + 1;
const transform = (value: I32) => increment(double value);

let gcd: [I32, I32] -> I32 = rec (left: I32, right: I32) => {
  if right == 0 {
    left
  } else {
    rec(right, left % right)
  }
};

(gcd(84, 30) |> transform) + 29
