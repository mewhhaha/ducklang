module (!init: Init) where

declare effect Io {
  read: () => Text
  print: (bounded_borrow Text) => Unit
}

declare Init {
  io: Io
}

let read_name: () -> <Io.read> Text = () => {
  name <- Io.read()
  name
}

let greet: () -> <Io.read | Io.print> Text = () => {
  name <- read_name()
  _ <- Io.print(borrow name)
  name
}

result <- greet()
return { result }
