module (!init: Init) where

declare effect Input {
  flag: () => I32
}

declare Init { input: Input }

const choice_type = union {
  add: Int,
  multiply: Int
}

flag <- Input.flag()
let choice: choice_type = if flag {
  choice_type.add(21)
} else {
  choice_type.multiply(2)
}

let operation = if let .add(amount) = choice {
  (value: Int) => value + amount
} else {
  (value: Int) => value * 2
}

let result: I32 = operation(21)
return { result }
