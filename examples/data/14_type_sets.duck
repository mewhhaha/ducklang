const { .length } = import "duck:prelude/runtime" ();

type Value = Int :| Text :| I64
type Answer = (Value :- Text) :& Int
type Marker = #answer
type FrozenText = #Text

const marker: Marker = #answer;
let greeting: FrozenText = "hello";
let view: &Text = &greeting;
let value: Value = 37;
let marker_matches = marker is #answer;

let answer: Answer = if value is Int {
  value + length view
} else {
  0
};

if marker_matches { answer } else { 0 }
